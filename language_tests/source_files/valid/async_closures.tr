// CHECK_ONLY

func applyAsync[F: AsyncFnOnce(int32) -> int32](_ f: F, _ x: int32) async -> int32 {
    return await f(x)
}

func applyZeroAsync[F: AsyncFnOnce() -> int32](_ f: F) async -> int32 {
    return await f()
}

func applyReusableAsync[F: AsyncFn(int32) -> int32](_ f: F, _ x: int32) async -> int32 {
    return await f(x)
}

func main() async {
    let captured = 7 as int32

    let zero = || async {
        await std.testing.yieldNow()
        return captured * 2
    }

    let unary = |x: int32| async {
        await std.testing.yieldNow()
        return x + captured
    }

    let sync = || {
        return captured - 1
    }

    let reusable = |x: int32| async {
        await std.testing.yieldNow()
        return x + 1
    }

    let _ = await applyZeroAsync(zero)
    let _ = await applyAsync(unary, 5)
    let _ = await applyReusableAsync(reusable, 5)
    let _ = sync()

    let spawned = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return captured + 1
    })
    let _ = await spawned.value()

    let inferredSpawnAwait = std.task.spawn(|| {
        await std.testing.yieldNow()
        return captured + 2
    })
    let _ = await inferredSpawnAwait.value()

    let inferredSpawnSyncBody = std.task.spawn(|| {
        return captured + 3
    })
    let _ = await inferredSpawnSyncBody.value()

    let _ = await applyZeroAsync(|| {
        return captured + 4
    })

    for i in 0..=2 {
        let task = std.task.spawn(|| async { return i })
        let _ = await task.value()
    }
}
