// CHECK_ONLY

import std.collections.List
import std.marker.Copy

struct Inner: Copy {
    value: int32
}

struct Outer: Copy {
    inner: Inner
}

func stdSugarCompileCoverage() {
    // Optional type + chaining + default
    let outer = Outer { inner: Inner { value: 7 } }
    let maybe_outer: Outer? = .some(outer)
    let maybe_value = maybe_outer?.inner.value
    let value = maybe_value ?? 0

    // Ternary
    let selected = value > 0 ? value : 1
    let _ = selected

    // Optional pattern binding (`if let`)
    let maybe_number: int32? = .some(3)
    if let n = maybe_number {
        let _ = n
    }

    // List type sugar + for-loop + range/closed-range sugar
    var numbers: [int32] = List()
    for i in 1_i32..=3_i32 {
        numbers.append(i)
    }

    var sum: int32 = 0
    for n in numbers {
        sum += n
    }
    let _ = sum

    // Dictionary type sugar + literal sugar
    let seeded: [int32: string] = [1: "one", 2: "two"]
    var empty: [int32: string] = [:]
    let _ = empty.insert(key: 3, value: "three")
    let _ = seeded.contains(1)

    // Half-open range sugar
    var count: int32 = 0
    for _ in 0_i32..3_i32 {
        count += 1
    }
    let _ = count
}

func main() {
    stdSugarCompileCoverage()
}
