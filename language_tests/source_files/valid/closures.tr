// Consolidated closure language tests.

// --- Fn helpers ---

func applyIntExplicit[F: Fn(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    f(x)
}

func mapValueExplicit[T, F: Fn(T) -> T](_ value: T, _ f: F) -> T {
    f(value)
}

struct IntBoxExplicit {
    value: int32
}

impl IntBoxExplicit {
    func map[F: Fn(int32) -> int32](&self, _ f: F) -> int32 {
        f(self.value)
    }
}

func applyFnPtr(_ f: (int32) -> int32, _ x: int32) -> int32 {
    f(x)
}

func applyFnSimple[F: Fn(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    f(x)
}

func applyOnceHierarchy[F: FnOnce(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    f(x)
}

func applyMutHierarchy[F: Fn(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    var f = f
    f(x)
}

func applyFnHierarchy[F: Fn(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    f(x)
}

func applyHigher[F: Fn(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    f(x)
}

func apply2Higher[F: Fn(int32, int32) -> int32](_ f: F, _ a: int32, _ b: int32) -> int32 {
    f(a, b)
}

func applyZeroHigher[F: Fn() -> int32](_ f: F) -> int32 {
    f()
}

func applyZeroMutTwice[F: Fn() -> int32](_ f: F) -> int32 {
    var f = f
    let first = f()
    let second = f()
    first + second
}

func applyZeroOnce[F: FnOnce() -> int32](_ f: F) -> int32 {
    f()
}

func applyMutTwice[F: Fn(int32) -> int32](_ f: F, _ a: int32, _ b: int32) -> int32 {
    var f = f
    let first = f(a)
    let second = f(b)
    first + second
}

func apply2MutHierarchy[F: Fn(int32, int32) -> int32](_ f: F, _ a: int32, _ b: int32) -> int32 {
    var f = f
    let first = f(a, b)
    let second = f(b, a)
    first + second
}

func apply2OnceHierarchy[F: FnOnce(int32, int32) -> int32](_ f: F, _ a: int32, _ b: int32) -> int32 {
    f(a, b)
}

func mapValHigher[F: Fn(int32) -> int32](_ value: int32, _ transform: F) -> int32 {
    transform(value)
}

func applyInferred[F: Fn(int32) -> int32](_ f: F, _ x: int32) -> int32 {
    f(x)
}

func apply2Inferred[F: Fn(int32, int32) -> int32](_ f: F, _ a: int32, _ b: int32) -> int32 {
    f(a, b)
}

func mapValInferred[T, F: Fn(T) -> T](_ value: T, _ f: F) -> T {
    f(value)
}

func applyOutFn[T, Out, F: Fn(T) -> Out](_ x: T, _ f: F) -> Out {
    f(x)
}

func applyOutMut[T, Out, F: Fn(T) -> Out](_ x: T, _ f: F) -> Out {
    var f = f
    f(x)
}

func applyOutOnce[T, Out, F: FnOnce(T) -> Out](_ x: T, _ f: F) -> Out {
    f(x)
}

// --- FnMut helpers ---

func applyMut[F: FnMut(int32) -> int32](_ f: F, _ a: int32, _ b: int32) -> int32 {
    var f = f
    let first = f(a)
    let second = f(b)
    return first + second
}

func applyZeroMut[F: FnMut() -> int32](_ f: F) -> int32 {
    var f = f
    let a = f()
    let b = f()
    let c = f()
    return a + b + c
}

// --- FnOnce helpers ---

func consumeViaOnce[F: FnOnce() -> int32](_ f: F) -> int32 {
    f()
}

func callTwice[F: Fn() -> int32](_ f: F) -> int32 {
    f() + f()
}

// --- Struct helpers ---

struct ContainerInferred {
    value: int32
}

impl ContainerInferred {
    func map[F: Fn(int32) -> int32](&self, _ f: F) -> int32 {
        f(self.value)
    }

    func transform[F: Fn(int32) -> int32, G: Fn(int32) -> int32](&self, _ f: F, _ g: G) -> int32 {
        g(f(self.value))
    }
}

struct ContainerMethod {
    value: int32
}

impl ContainerMethod {
    func map[F: Fn(int32) -> int32](&self, _ f: F) -> int32 {
        f(self.value)
    }

    func map_once[F: FnOnce(int32) -> int32](&self, _ f: F) -> int32 {
        f(self.value)
    }

    func transform[F: Fn(int32) -> int32, G: Fn(int32) -> int32](&self, _ f: F, _ g: G) -> int32 {
        g(f(self.value))
    }
}

struct PairMethod {
    a: int32
    b: int32
}

impl PairMethod {
    func combine[F: Fn(int32, int32) -> int32](&self, _ f: F) -> int32 {
        f(self.a, self.b)
    }
}

struct ContainerMethodGeneric[T] {
    value: T
}

impl[T] ContainerMethodGeneric[T] {
    func map[F: Fn(T) -> T](self, _ f: F) -> T {
        f(self.value)
    }

    func map_once[F: FnOnce(T) -> T](self, _ f: F) -> T {
        f(self.value)
    }
}

struct PairMethodGeneric[T] {
    first: T
    second: T
}

impl[T] PairMethodGeneric[T] {
    func combine[F: Fn(T, T) -> T](self, _ f: F) -> T {
        f(self.first, self.second)
    }

    func map_both[F: Fn(T) -> T](self, _ f: F) -> PairMethodGeneric[T] {
        PairMethodGeneric[T] { first: f(self.first), second: f(self.second) }
    }
}

struct CallableField[F: Fn(int32) -> int32] {
    f: F
}

impl[F: Fn(int32) -> int32] CallableField[F] {
    func apply(&mut self, _ x: int32) -> int32 {
        self.f(x)
    }
}

func applyGenericMethod[T, F: Fn(T) -> T](_ f: F, _ x: T) -> T {
    f(x)
}

func composeGenericMethod[T, F: Fn(T) -> T, G: Fn(T) -> T](_ f: F, _ g: G, _ x: T) -> T {
    let intermediate = f(x)
    g(intermediate)
}

func consumeListMove(_ list: List[int32]) {
}

// --- Generic capture helpers ---

func wrapAndConsume[T](_ value: T, _ check: (T) -> int32) -> int32 {
    let closure = || { check(value) }
    return consumeViaOnce(closure)
}

func wrapCopyable[T: Copy](_ value: T, _ check: (T) -> int32) -> int32 {
    let closure = || { check(value) }
    return callTwice(closure)
}

// === Tests ===

func testClosureBasic() {
    let add = |a: int32, b: int32| -> int32 { a + b }
    let result = add(2, 3)
    std.assert(result == 5, "add(2, 3) should be 5")

    let square = |x: int32| -> int32 { x * x }
    std.assert(square(4) == 16, "square(4) should be 16")

    let get_five = || -> int32 { 5 }
    std.assert(get_five() == 5, "get_five() should be 5")

    let x: int32 = 10
    let add_x = |y: int32| -> int32 { x + y }
    std.assert(add_x(5) == 15, "add_x(5) should be 15")

    let a: int32 = 3
    let b: int32 = 4
    let sum_ab = || -> int32 { a + b }
    std.assert(sum_ab() == 7, "sum_ab() should be 7")
}

func testClosureByRef() {
    var list = List[int32]()
    list.append(1)
    list.append(2)

    let get_len = || -> int32 { list.len() as int32 }
    std.assert(get_len() == 2, "list length should be 2")
}

func testClosureDeep() {
    let a: int32 = 1
    let deep = || -> int32 {
        let b: int32 = 2
        let mid = || -> int32 {
            let c: int32 = 3
            let inner = || -> int32 { a + b + c }
            inner()
        }
        mid()
    }
    std.assert(deep() == 6, "deeply nested should compute 1+2+3 = 6")
}

func testClosureExplicitParams() {
    let result1 = applyIntExplicit(|x: int32| -> int32 { x * 2 }, 5)
    std.assert(result1 == 10, "apply_int should work")

    let result2 = mapValueExplicit(10, |x: int32| -> int32 { x + 5 })
    std.assert(result2 == 15, "map_value should work")

    let box = IntBoxExplicit { value: 20 }
    let result3 = box.map(|x: int32| -> int32 { x / 2 })
    std.assert(result3 == 10, "IntBox.map should work")

    let outer = |a: int32| -> int32 {
        let inner = |b: int32| -> int32 { b * 2 }
        inner(a) + 1
    }
    let result4 = outer(5)
    std.assert(result4 == 11, "nested closure should work")

    let base: int32 = 100
    let add_base = |x: int32| -> int32 { x + base }
    let result5 = applyIntExplicit(add_base, 50)
    std.assert(result5 == 150, "capturing closure inference")

    let double = |x: int32| -> int32 { x * 2 }
    let triple = |x: int32| -> int32 { x * 3 }
    let r6a = applyIntExplicit(double, 5)
    let r6b = applyIntExplicit(triple, 5)
    std.assert(r6a == 10, "double should work")
    std.assert(r6b == 15, "triple should work")
}

func testClosureFnPtr() {
    let double: (int32) -> int32 = |x: int32| -> int32 { x * 2 }

    let result = applyFnPtr(double, 5)
    std.assert(result == 10, "double(5) should be 10")

    let result2 = applyFnPtr(|x: int32| -> int32 { x + 100 }, 7)
    std.assert(result2 == 107, "closure(7) should be 107")

    let get_42: () -> int32 = || -> int32 { 42 }
    std.assert(get_42() == 42, "get_42() should be 42")
}

func testClosureFnSimple() {
    let result = applyFnSimple(|x: int32| -> int32 { x * 2 }, 5)
    std.assert(result == 10, "should be 10")
}

func testClosureFnCopyCaptureSemantics() {
    var counter: int32 = 0
    let inc = || -> int32 { counter + 1 }
    let first = inc()
    let second = inc()
    std.assert(first == 1, "first call should use copied capture")
    std.assert(second == 1, "second call should use copied capture")
    std.assert(counter == 0, "outer counter should remain unchanged under by-copy capture")
}

func testClosureHierarchy() {
    let multiplier: int32 = 2

    let r1 = applyFnHierarchy(|x: int32| -> int32 { x * multiplier }, 5)
    std.assert(r1 == 10, "apply_fn should work with Fn closure")

    let r2 = applyMutHierarchy(|x: int32| -> int32 { x * multiplier }, 5)
    std.assert(r2 == 10, "apply_mut should accept Fn closure via hierarchy")

    let r3 = applyOnceHierarchy(|x: int32| -> int32 { x * multiplier }, 5)
    std.assert(r3 == 10, "apply_once should accept Fn closure via hierarchy")

    let r4 = applyOnceHierarchy(|x: int32| -> int32 { x + 1 }, 5)
    std.assert(r4 == 6, "non-capturing Fn closure in apply_once")

    let r5 = applyMutHierarchy(|x: int32| -> int32 { x * 3 }, 4)
    std.assert(r5 == 12, "non-capturing Fn closure in apply_mut")
}

func testClosureHigherOrder() {
    let doubled = applyHigher(|x: int32| -> int32 { x * 2 }, 5)
    std.assert(doubled == 10, "apply double(5) should be 10")

    let multiplier: int32 = 3
    let tripled = applyHigher(|x: int32| -> int32 { x * multiplier }, 4)
    std.assert(tripled == 12, "apply triple(4) should be 12")

    let sum = apply2Higher(|a: int32, b: int32| -> int32 { a + b }, 10, 20)
    std.assert(sum == 30, "apply2 sum(10, 20) should be 30")

    let result = mapValHigher(5, |x: int32| -> int32 { x + 10 })
    let result2 = mapValHigher(result, |x: int32| -> int32 { x * 2 })
    std.assert(result2 == 30, "chained map should be 30")
}

func testClosureInferred() {
    let doubled = applyInferred(|x| { x * 2 }, 5)
    std.assert(doubled == 10, "apply with inferred param should work")

    let multiplier: int32 = 3
    let tripled = applyInferred(|x| { x * multiplier }, 4)
    std.assert(tripled == 12, "capturing closure with inferred param")

    let sum = apply2Inferred(|a, b| { a + b }, 10, 20)
    std.assert(sum == 30, "two-arg closure with inferred params")

    let container = ContainerInferred { value: 10 }
    let result = container.map(|x| { x + 5 })
    std.assert(result == 15, "method with inferred closure param")

    let chained = container.transform(|x| { x * 2 }, |x| { x + 1 })
    std.assert(chained == 21, "chained closures with inferred params")

    let mixed = applyInferred(|x| -> int32 { x * 10 }, 5)
    std.assert(mixed == 50, "explicit return type, inferred param")

    let outer_val: int32 = 100
    let nested = applyInferred(|x| {
        let inner = applyInferred(|y| { y + outer_val }, x)
        inner * 2
    }, 5)
    std.assert(nested == 210, "nested closures with inferred params")
}

func testClosureGenericOutInference() {
    let doubled = applyOutFn(5 as int32, |x: int32| { x * 2 })
    std.assert(doubled == 10, "Out should infer to int32")

    let is_even = applyOutFn(6 as int32, |x: int32| { x % 2 == 0 })
    std.assert(is_even, "Out should infer to bool")

    let running = applyOutMut(3 as int32, |x: int32| { x + 1 })
    std.assert(running == 4, "Fn Out inference should work")

    let once_result = applyOutOnce(9 as int32, |x: int32| { x + 1 })
    std.assert(once_result == 10, "Fn Out inference should work")
}

func testClosureMethod() {
    let container = ContainerMethod { value: 10 }

    let doubled = container.map(|x: int32| -> int32 { x * 2 })
    std.assert(doubled == 20, "map double should be 20")

    let multiplier: int32 = 3
    let tripled = container.map(|x: int32| -> int32 { x * multiplier })
    std.assert(tripled == 30, "map triple should be 30")

    let offset: int32 = 5
    let result_once = container.map_once(|x: int32| -> int32 { x + offset })
    std.assert(result_once == 15, "map_once should be 15")

    let chained = container.transform(
        |x: int32| -> int32 { x + 5 },
        |x: int32| -> int32 { x * 2 },
    )
    std.assert(chained == 30, "transform (10+5)*2 should be 30")

    let pair = PairMethod { a: 10, b: 20 }
    let sum = pair.combine(|a: int32, b: int32| -> int32 { a + b })
    std.assert(sum == 30, "combine sum should be 30")
}

func testClosureMethodGeneric() {
    let int_container = ContainerMethodGeneric[int32] { value: 10 }

    let doubled = int_container.map(|x: int32| -> int32 { x * 2 })
    std.assert(doubled == 20, "int map should work")

    let container2 = ContainerMethodGeneric[int32] { value: 10 }
    let incremented = container2.map_once(|x: int32| -> int32 { x + 1 })
    std.assert(incremented == 11, "map_once should work")

    let container3 = ContainerMethodGeneric[int32] { value: 10 }
    let multiplier: int32 = 5
    let result = container3.map(|x: int32| -> int32 { x * multiplier })
    std.assert(result == 50, "capturing closure with generic method")

    let int_pair = PairMethodGeneric[int32] { first: 3, second: 7 }

    let sum = int_pair.combine(|a: int32, b: int32| -> int32 { a + b })
    std.assert(sum == 10, "pair combine should work")

    let pair2 = PairMethodGeneric[int32] { first: 3, second: 7 }
    let product = pair2.combine(|a: int32, b: int32| -> int32 { a * b })
    std.assert(product == 21, "pair combine product")

    let pair3 = PairMethodGeneric[int32] { first: 3, second: 7 }
    let doubled_pair = pair3.map_both(|x: int32| -> int32 { x * 2 })
    std.assert(doubled_pair.first == 6, "map_both first")
    std.assert(doubled_pair.second == 14, "map_both second")

    let applied = applyGenericMethod(|x: int32| -> int32 { x + 100 }, 5)
    std.assert(applied == 105, "apply_generic should work")

    let composed = composeGenericMethod(
        |x: int32| -> int32 { x * 2 },
        |x: int32| -> int32 { x + 1 },
        5,
    )
    std.assert(composed == 11, "compose (5*2)+1 = 11")
}

func testCallableFieldDispatch() {
    var add_one = CallableField { f: |x: int32| -> int32 { x + 1 } }
    std.assert(add_one.apply(10) == 11, "self.f(x) should dispatch callable field")

    var accumulator = CallableField {
        f: |x: int32| -> int32 { x * 2 },
    }

    let first = accumulator.apply(3)
    let second = accumulator.apply(4)
    std.assert(first == 6, "first call should return doubled value")
    std.assert(second == 8, "second call should return doubled value")
}

func testClosureMove() {
    var list = List[int32]()
    list.append(1)

    let consume = || { consumeListMove(list) }
    consume()
}

func testClosureNested() {
    let x: int32 = 10

    let outer = || -> int32 {
        let inner = || -> int32 { x }
        inner()
    }
    std.assert(outer() == 10, "simple nested should return 10")

    let y: int32 = 20
    let outer2 = || -> int32 {
        let inner = || -> int32 { x + y }
        inner() + 5
    }
    std.assert(outer2() == 35, "nested with computation should return 35")

    let result = (|| -> int32 {
        (|| -> int32 { x * 2 })()
    })()
    std.assert(result == 20, "immediate call nested should return 20")
}

func testClosureShorthandStress() {
    let zero = applyZeroHigher(|| -> int32 { 99 })
    std.assert(zero == 99, "zero-arg Fn shorthand should dispatch through generic helper")

    let immediate_zero = applyZeroHigher((|| -> int32 { 123 }))
    std.assert(immediate_zero == 123, "immediate zero-arg closure should materialize a self place")

    let zero_mut_sum = applyZeroMutTwice(|| -> int32 { 1 })
    std.assert(zero_mut_sum == 2, "zero-arg Fn helper should call closure twice")

    let mut_sum = applyMutTwice(|x: int32| -> int32 { x + 1 }, 3, 4)
    std.assert(mut_sum == 9, "Fn helper should apply closure to each argument")

    var list = List[int32]()
    list.append(4)
    list.append(5)
    let once_len = applyZeroOnce(|| -> int32 {
        let len = list.len() as int32
        consumeListMove(list)
        len
    })
    std.assert(once_len == 2, "Fn helper should accept non-Copy captured values by move")

    let pair_mut_sum = apply2MutHierarchy(|a: int32, b: int32| -> int32 { a + b }, 1, 2)
    std.assert(pair_mut_sum == 6, "two-arg Fn shorthand should run twice and sum results")

    var pair_list = List[int32]()
    pair_list.append(10)
    let pair_once = apply2OnceHierarchy(|a: int32, b: int32| -> int32 {
        let len = pair_list.len() as int32
        consumeListMove(pair_list)
        a + b + len
    }, 3, 4)
    std.assert(pair_once == 8, "two-arg Fn shorthand should consume captured values correctly")
}

// --- FnMut dispatch tests ---

func testFnMutNonCapturing() {
    let result = applyMut(|x: int32| -> int32 { x * 2 }, 3, 5)
    assert(result == 16, "non-capturing closure through FnMut(int32)->int32 should work")
}

func testFnMutListCapture() {
    var items: std.collections.List[int32] = std.collections.List()
    let acc = |val: int32| -> int32 {
        items.append(val)
        return items.len() as int32
    }
    let result = applyMut(acc, 10, 20)
    assert(result == 3, "mutating List closure through FnMut(int32)->int32: 1+2=3")
    assert(items.len() == 2 as usize, "List should have two items after applyMut")
}

func testFnMutZeroArgListCapture() {
    var growing: std.collections.List[int32] = std.collections.List()
    let inc = || -> int32 {
        growing.append(1)
        return growing.len() as int32
    }
    let sum = applyZeroMut(inc)
    assert(sum == 6, "mutating List closure through FnMut()->int32: 1+2+3=6")
    assert(growing.len() == 3 as usize, "List should have three items after applyZeroMut")
}

func testFnMutListCaptureWithArg() {
    var items: std.collections.List[int32] = std.collections.List()
    var push = |val: int32| {
        items.append(val)
    }
    push(10)
    push(20)
    push(30)
    assert(items.len() == 3, "closure should mutate captured list")
}

// --- FnMut scalar mutable capture tests ---

func testFnMutScalarCaptureThroughHelper() {
    var counter: int32 = 0
    let inc = || -> int32 {
        counter = counter + 1
        return counter
    }
    let sum = applyZeroMut(inc)
    assert(sum == 6, "scalar mutable capture through FnMut should accumulate: 1+2+3=6")
    assert(counter == 3, "outer counter should reflect mutations after applyZeroMut")
}

func testFnMutScalarCaptureDirectCalls() {
    var counter: int32 = 0
    var inc = || -> int32 {
        counter = counter + 1
        return counter
    }
    let a = inc()
    let b = inc()
    let c = inc()
    assert(a == 1, "first direct call should return 1")
    assert(b == 2, "second direct call should return 2")
    assert(c == 3, "third direct call should return 3")
    assert(counter == 3, "outer counter should be 3 after three direct calls")
}

func testFnMutScalarCaptureWithArg() {
    var total: int32 = 0
    let acc = |val: int32| -> int32 {
        total = total + val
        return total
    }
    let result = applyMut(acc, 10, 20)
    assert(result == 40, "scalar accumulator through FnMut(int32)->int32: 10+30=40")
    assert(total == 30, "outer total should be 30 after accumulating 10 and 20")
}

// --- Generic closure move semantics tests ---

func testGenericClosureNonCopyCapture() {
    let result = wrapAndConsume(42 as int32, |x| { x })
    assert(result == 42, "non-copy generic capture via FnOnce")
}

func testGenericClosureCopyCapture() {
    let result = wrapCopyable(10 as int32, |x| { x })
    assert(result == 20, "copy generic capture via Fn called twice")
}

// === Main ===

func main() {
    testClosureBasic()
    testClosureByRef()
    testClosureDeep()
    testClosureExplicitParams()
    testClosureFnPtr()
    testClosureFnSimple()
    testClosureFnCopyCaptureSemantics()
    testClosureHierarchy()
    testClosureHigherOrder()
    testClosureInferred()
    testClosureGenericOutInference()
    testClosureMethod()
    testClosureMethodGeneric()
    testCallableFieldDispatch()
    testClosureMove()
    testClosureNested()
    testClosureShorthandStress()
    testFnMutNonCapturing()
    testFnMutListCapture()
    testFnMutZeroArgListCapture()
    testFnMutListCaptureWithArg()
    testFnMutScalarCaptureThroughHelper()
    testFnMutScalarCaptureDirectCalls()
    testFnMutScalarCaptureWithArg()
    testGenericClosureNonCopyCapture()
    testGenericClosureCopyCapture()

    std.print("PASS: closures\n")
}
