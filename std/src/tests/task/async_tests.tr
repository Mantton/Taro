import std.optional.Optional

func durationToNanos(_ d: std.time.Duration) -> uint64 {
    return (d.seconds() * 1000000000_u64) + (d.subsecNanos() as uint64)
}

func stringBytes(_ s: string) -> std.mem.Span[uint8] {
    return std.mem.Span[uint8].from(std.string.stringData(s), std.string.stringLen(s))
}

@cfg(family("unix"))
static var PIPE_WRITER_STREAM: Optional[std.io.task.AsyncStream] = .none

@cfg(family("unix"))
static var SHARED_PIPE_READ_STREAM: Optional[std.io.task.AsyncStream] = .none

@cfg(family("unix"))
static var SHARED_PIPE_WRITE_STREAM: Optional[std.io.task.AsyncStream] = .none

@cfg(family("unix"))
func sharedPipeReaderBody() async -> int32 {
    let reader = match SHARED_PIPE_READ_STREAM {
        case .some(value) => value
        case .none => std.panic.panic("shared pipe reader should be seeded before spawning")
    }

    var byte: uint8 = 0
    let readRes = await reader.read(std.mem.MutableSpan[uint8].from(unsafe { (&mut byte) as *mut uint8 }, 1))
    let readCount = match readRes {
        case .ok(count) => count
        case .err(_) => std.panic.panic("shared pipe reader should succeed")
    }
    std.testing.assertEqual(readCount, 1, "shared pipe reader should receive one byte")
    return byte as int32
}

@cfg(family("unix"))
func sharedPipeWriterBody() async -> int32 {
    let writer = match SHARED_PIPE_WRITE_STREAM {
        case .some(value) => value
        case .none => std.panic.panic("shared pipe writer should be seeded before spawning")
    }

    await std.testing.yieldNow()
    let writeRes = await writer.write(stringBytes("ab"))
    let written = match writeRes {
        case .ok(count) => count
        case .err(_) => std.panic.panic("shared pipe writer should succeed")
    }
    match writer.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("shared pipe writer close should succeed")
    }
    return written as int32
}

@cfg(family("unix"))
func pipeWriterBody() async -> int32 {
    let seeded = match PIPE_WRITER_STREAM.take() {
        case .some(value) => value
        case .none => std.panic.panic("pipe writer seed should be set before spawning")
    }

    let writer = seeded
    await std.testing.yieldNow()
    let writeRes = await writer.write(stringBytes("ping"))
    let written = match writeRes {
        case .ok(count) => count
        case .err(err) => std.panic.panic("pipe writer should succeed")
    }
    let closeRes = writer.close()
    match closeRes {
        case .ok(_) => {}
        case .err(err) => std.panic.panic("pipe writer close should succeed")
    }
    return written as int32
}

func asyncValue() async -> int32 {
    return 7
}

func asyncAwaitValue() async -> int32 {
    return await asyncValue()
}

func delayedAsyncValue() async -> int32 {
    await std.testing.yieldNow()
    return 9
}

func delayedNestedAwaitValue() async -> int32 {
    return await delayedAsyncValue()
}

func multiAwaitValue() async -> int32 {
    await std.testing.yieldNow()
    await std.testing.yieldNow()
    return 13
}

@test
func asyncFunctionsReturnValues() async {
    let value = await asyncValue()
    std.testing.assertEqual(value, 7, "async fn should resolve to its declared value")
}

@test
func awaitUnwrapsAsyncCalls() async {
    let value = await asyncAwaitValue()
    std.testing.assertEqual(value, 7, "await should unwrap async function calls")
}

@test
func suspendingAsyncFunctionsResumeThroughAwait() async {
    let value = await delayedAsyncValue()
    std.testing.assertEqual(value, 9, "async fn should resume after pending")
}

@test
func nestedAwaitsPropagateSuspension() async {
    let value = await delayedNestedAwaitValue()
    std.testing.assertEqual(value, 9, "await should resume nested pending async calls")
}

@test
func asyncFunctionsHandleMultipleAwaitPoints() async {
    let value = await multiAwaitValue()
    std.testing.assertEqual(value, 13, "async fn should handle multiple suspension points")
}

func asyncChainC() async -> int32 {
    await std.testing.yieldNow()
    return 100
}

func asyncChainB() async -> int32 {
    return (await asyncChainC()) + 1
}

func asyncChainA() async -> int32 {
    return (await asyncChainB()) + 1
}

@test
func deepAwaitChainsResolveCorrectly() async {
    let value = await asyncChainA()
    std.testing.assertEqual(value, 102, "A -> B -> C chain should resolve to 102")
}

func asyncAdd(_ x: int32, _ y: int32) async -> int32 {
    await std.testing.yieldNow()
    return x + y
}

@test
func asyncFunctionsPreserveParameters() async {
    let value = await asyncAdd(13, 29)
    std.testing.assertEqual(value, 42, "parameters should survive across yield")
}

func gcSuspendedTaskValue(_ captured: int32) async -> int32 {
    await std.task.sleep(std.time.Duration.fromMillis(10_u64))
    return captured
}

@test
func suspendedSpawnedTasksSurviveManualGc() async {
    let taskCount = 17_i32
    var tasks = std.collections.List[std.task.Task[int32]]()

    var idx: int32 = 0
    while idx < taskCount {
        let captured = idx + 1_i32
        let task = std.task.spawn(|| async {
            return await gcSuspendedTaskValue(captured)
        })
        tasks.append(task)
        idx += 1_i32
    }

    std.runtime.collect()

    var sum: int32 = 0
    while !tasks.isEmpty() {
        let task = match tasks.pop() {
            case .some(t) => t
            case .none => std.panic.panic("task list should not be empty")
        }
        let value = await task.value()
        sum += value
    }

    std.testing.assertEqual(sum, 153_i32, "manual GC should preserve suspended spawned task frames")
}

struct AsyncPoint {
    x: int32
    y: int32
}

func asyncPoint() async -> AsyncPoint {
    await std.testing.yieldNow()
    return AsyncPoint { x: 3, y: 4 }
}

@test
func asyncFunctionsReturnStructs() async {
    let p = await asyncPoint()
    std.testing.assertEqual(p.x, 3, "struct x field should be 3")
    std.testing.assertEqual(p.y, 4, "struct y field should be 4")
}

func asyncManyLocals() async -> int32 {
    let a = 1 as int32
    let b = 2 as int32
    let c = 3 as int32
    let d = 4 as int32
    let e = 5 as int32
    await std.testing.yieldNow()
    let f = 6 as int32
    let g = 7 as int32
    await std.testing.yieldNow()
    return a + b + c + d + e + f + g
}

@test
func asyncFunctionsPreserveLocalsAcrossYields() async {
    let value = await asyncManyLocals()
    std.testing.assertEqual(value, 28, "all locals should be preserved across multiple yields")
}

func asyncConditional(_ flag: bool) async -> int32 {
    await std.testing.yieldNow()
    if flag {
        return 42
    }
    return 0
}

@test
func asyncFunctionsHandleConditionalPaths() async {
    let a = await asyncConditional(true)
    let b = await asyncConditional(false)
    std.testing.assertEqual(a, 42, "true branch should return 42")
    std.testing.assertEqual(b, 0, "false branch should return 0")
}

func asyncVoid(_ x: *mut int32) async {
    await std.testing.yieldNow()
    unsafe { x.write(99) }
}

@test
func voidAsyncFunctionsComplete() async {
    var sentinel: int32 = 0
    await asyncVoid(unsafe { (&mut sentinel) as *mut int32 })
    std.testing.assertEqual(sentinel, 99, "void async fn should complete and apply side effect")
}

func asyncWithStrings() async -> string {
    let a = "hello"
    await std.testing.yieldNow()
    let b = " world"
    await std.testing.yieldNow()
    return a + b
}

func asyncHoldList() async -> int32 {
    var items: std.collections.List[int32] = std.collections.List()
    items.append(10)
    await std.testing.yieldNow()
    items.append(20)
    await std.testing.yieldNow()
    items.append(30)
    return *items.at(0 as usize) + *items.at(1 as usize) + *items.at(2 as usize)
}

func applyAsyncClosure[F: std.ops.AsyncFnOnce(int32) -> int32](_ f: F, _ x: int32) async -> int32 {
    return await f(x)
}

func applyReusableAsyncClosure[F: std.ops.AsyncFn(int32) -> int32](_ f: F, _ x: int32) async -> int32 {
    return await f(x)
}

@test
func stringsSurviveAcrossYields() async {
    let value = await asyncWithStrings()
    std.testing.assertEqual(value, "hello world", "strings should survive across yield points")
}

@test
func listsSurviveAcrossYields() async {
    let value = await asyncHoldList()
    std.testing.assertEqual(value, 60, "list should survive across yield points")
}

@test
func asyncClosuresCaptureAcrossYields() async {
    let captured = 5 as int32
    let addCaptured = |x: int32| async {
        std.println("before yield, x=" + std.sprintf("%d", x) + " captured=" + std.sprintf("%d", captured))
        await std.testing.yieldNow()
        std.println("after yield, x=" + std.sprintf("%d", x) + " captured=" + std.sprintf("%d", captured))
        return x + captured
    }

    let value = await addCaptured(7)
    std.println("value=" + std.sprintf("%d", value))
    std.testing.assertEqual(value, 12, "async closures should capture locals across yields")
}

@test
func asyncClosuresSatisfyAsyncFnOnceBounds() async {
    let captured = 9 as int32
    let closure = |x: int32| async {
        await std.testing.yieldNow()
        return x + captured
    }

    let value = await applyAsyncClosure(closure, 3)
    std.testing.assertEqual(value, 12, "capturing async closures should satisfy AsyncFnOnce bounds")
}

@test
func noncapturingAsyncClosuresSatisfyAsyncFnBounds() async {
    let closure = |x: int32| async {
        await std.testing.yieldNow()
        return x + 9
    }

    let value = await applyReusableAsyncClosure(closure, 3)
    std.testing.assertEqual(value, 12, "noncapturing async closures should satisfy AsyncFn bounds")
}

@test
func spawnedTasksComplete() async {
    let captured = 5 as int32
    let task = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return captured + 10
    })

    let result = await task.value()
    std.testing.assertEqual(result, 15, "spawned task should resolve")
}

@test
func joinReturnsBothTaskValues() async {
    let intTask = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return 17 as int32
    })
    let stringTask = std.task.spawn(|| async {
        return "joined"
    })

    let joined = await std.task.join(intTask, stringTask)
    std.testing.assertEqual(joined.0, 17, "join should preserve the left task result")
    std.testing.assertEqual(joined.1, "joined", "join should preserve the right task result")
}

@test
func joinHandlesDifferentCompletionTiming() async {
    let slow = std.task.spawn(|| async {
        await std.task.sleep(std.time.Duration.fromMillis(5_u64))
        return "slow"
    })
    let fast = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return 99 as int32
    })

    let joined = await std.task.join(slow, fast)
    std.testing.assertEqual(joined.0, "slow", "join should return the slower left task result")
    std.testing.assertEqual(joined.1, 99, "join should return the faster right task result")
}

@test
@expectPanic
func joinPropagatesTaskPanic() async {
    let left = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return 7 as int32
    })
    let right = std.task.spawn(|| async {
        await std.testing.yieldNow()
        std.panic.panic("joined task panic should fail the awaiter")
    })

    let _ = await std.task.join(left, right)
}

@test
func zeroDurationSleepCompletesImmediately() async {
    // With a multi-worker executor both tasks run on separate threads, so
    // comparing wall-clock timestamps across them is non-deterministic.
    // The real invariant is that a zero-duration sleep does not block forever.
    let sleeper = std.task.spawn(|| async {
        await std.task.sleep(std.time.Duration.fromNanos(0_u64))
        return 1 as int32
    })
    let yielded = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return 2 as int32
    })

    let sleeperResult = await sleeper.value()
    let yieldedResult = await yielded.value()
    std.testing.assertEqual(sleeperResult, 1, "zero-duration sleep task should complete")
    std.testing.assertEqual(yieldedResult, 2, "yielded task should complete")
}

@test
func sleepDelaysExecution() async {
    let start = std.time.Instant.now()
    await std.task.sleep(std.time.Duration.fromMillis(5_u64))
    let elapsed = start.elapsed()
    std.testing.assertTrue(
        durationToNanos(elapsed) >= 1000000_u64,
        "sleep should measurably delay execution",
    )
}

@test
func spawnedSleepersWakeInDeadlineOrder() async {
    let short = std.task.spawn(|| async {
        await std.task.sleep(std.time.Duration.fromMillis(1_u64))
        return std.time.Instant.now()
    })
    let long = std.task.spawn(|| async {
        await std.task.sleep(std.time.Duration.fromMillis(5_u64))
        return std.time.Instant.now()
    })

    let shortAt = await short.value()
    let longAt = await long.value()
    let gap = longAt.checkedDurationSince(shortAt)
    std.testing.assertTrue(gap.isSome(), "shorter sleepers should wake no later than longer sleepers")
    std.testing.assertTrue(durationToNanos(gap.unwrap()) > 0_u64, "shorter sleepers should wake before longer sleepers")
}

@test
func multipleSpawnedTasksInterleave() async {
    let a = std.task.spawn(|| async {
        await std.testing.yieldNow()
        await std.testing.yieldNow()
        return 11 as int32
    })
    let b = std.task.spawn(|| async {
        await std.testing.yieldNow()
        return 12 as int32
    })

    let x = await a.value()
    let y = await b.value()
    std.testing.assertEqual(x + y, 23, "both spawned tasks should complete")
}

@test
@expectPanic
func spawnedTaskPanicAfterAsyncRootStillFailsTest() async {
    let _ = std.task.spawn(|| async {
        await std.testing.yieldNow()
        std.panic.panic("post-root spawned panic should still fail the async test")
    })
}

@test
@expectPanic
func syncSpawnedTaskPanicIsAttributedToTest() {
    let _ = std.task.spawn(|| async {
        await std.testing.yieldNow()
        std.panic.panic("spawned task panic should fail the sync test")
    })
}

@cfg(family("unix"))
@test
func asyncStreamPipeRoundTrip() async {
    let pipeRes = std.io.task.pipe()
    let pipePair = match pipeRes {
        case .ok(value) => value
        case .err(err) => std.panic.panic("pipe() should succeed on unix")
    }
    let readEnd = pipePair.0
    let writeEnd = pipePair.1

    var writerSeed = writeEnd
    PIPE_WRITER_STREAM = .some(writerSeed)
    let writerTask = std.task.spawn(|| async {
        return await pipeWriterBody()
    })

    let reader = readEnd
    var storage: [uint8; 4] = [0; 4]
    let storagePtr = unsafe { (&mut storage as *mut [uint8; 4]) as *mut uint8 }
    let readRes = await reader.read(std.mem.MutableSpan[uint8].from(storagePtr, 4))
    let readCount = match readRes {
        case .ok(count) => count
        case .err(err) => std.panic.panic("pipe reader should succeed")
    }

    std.testing.assertEqual(readCount, 4, "pipe reader should receive the full payload")
    std.testing.assertEqual(*storage.at(0 as usize), 112_u8, "first byte should be 'p'")
    std.testing.assertEqual(*storage.at(1 as usize), 105_u8, "second byte should be 'i'")
    std.testing.assertEqual(*storage.at(2 as usize), 110_u8, "third byte should be 'n'")
    std.testing.assertEqual(*storage.at(3 as usize), 103_u8, "fourth byte should be 'g'")

    let written = await writerTask.value()
    std.testing.assertEqual(written, 4, "pipe writer should report the written byte count")

    let eofRes = await reader.read(std.mem.MutableSpan[uint8].from(storagePtr, 4))
    let eofCount = match eofRes {
        case .ok(count) => count
        case .err(err) => std.panic.panic("pipe reader should observe EOF after writer close")
    }
    std.testing.assertEqual(eofCount, 0, "closing the pipe writer should produce EOF on the reader")

    let closeRes = reader.close()
    match closeRes {
        case .ok(_) => {}
        case .err(err) => std.panic.panic("pipe reader close should succeed")
    }
}

@cfg(family("unix"))
@test
func asyncStreamSupportsConcurrentReadWaiters() async {
    let pipeRes = std.io.task.pipe()
    let pipePair = match pipeRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("pipe() should succeed on unix")
    }

    SHARED_PIPE_READ_STREAM = .some(pipePair.0)
    SHARED_PIPE_WRITE_STREAM = .some(pipePair.1)
    let firstReader = std.task.spawn(|| async {
        return await sharedPipeReaderBody()
    })
    let secondReader = std.task.spawn(|| async {
        return await sharedPipeReaderBody()
    })
    let writer = std.task.spawn(|| async {
        return await sharedPipeWriterBody()
    })

    let firstByte = await firstReader.value()
    let secondByte = await secondReader.value()
    let written = await writer.value()
    std.testing.assertEqual(written, 2, "shared pipe writer should write both bytes")
    std.testing.assertTrue(firstByte != secondByte, "separate read waiters should each receive one byte")
    std.testing.assertEqual(firstByte + secondByte, 195, "shared waiters should receive the written byte payload")
    SHARED_PIPE_READ_STREAM = .none
    SHARED_PIPE_WRITE_STREAM = .none
}

func applyAsyncMut[F: std.ops.AsyncFnMut(int32) -> int32](_ f: F, _ x: int32) async -> int32 {
    var f = f
    let first = await f(x)
    let second = await f(x)
    return first + second
}

func applyZeroAsyncMut[F: std.ops.AsyncFnMut() -> int32](_ f: F) async -> int32 {
    var f = f
    let a = await f()
    let b = await f()
    let c = await f()
    return a + b + c
}

@test
func asyncClosuresSatisfyAsyncFnMutBounds() async {
    let closure = |x: int32| async {
        await std.testing.yieldNow()
        return x * 3
    }
    let value = await applyAsyncMut(closure, 5)
    // 5*3 + 5*3 = 30
    std.testing.assertEqual(value, 30, "non-capturing async closure should satisfy AsyncFnMut and be reusable")
}

@test
func asyncClosuresReusedThroughZeroArgAsyncFnMut() async {
    let closure = || async {
        await std.testing.yieldNow()
        return 7 as int32
    }
    let sum = await applyZeroAsyncMut(closure)
    // 7 + 7 + 7 = 21
    std.testing.assertEqual(sum, 21, "non-capturing async closure should be reusable through AsyncFnMut() bound")
}
