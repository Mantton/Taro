//+cfg family("unix")

@test
func testUnixErrnoMapperKnownCodes() {
    match std.sys.io.mapErrno(2) {
        case .notFound => {}
        case _ => std.panic.panic("ENOENT should map to notFound")
    }

    match std.sys.io.mapErrno(13) {
        case .permissionDenied => {}
        case _ => std.panic.panic("EACCES should map to permissionDenied")
    }

    match std.sys.io.mapErrno(32) {
        case .brokenPipe => {}
        case _ => std.panic.panic("EPIPE should map to brokenPipe")
    }

}

@cfg(os("linux"))
@test
func testUnixErrnoMapperWouldBlockLinux() {
    match std.sys.io.mapErrno(11) {
        case .wouldBlock => {}
        case _ => std.panic.panic("linux EWOULDBLOCK should map to wouldBlock")
    }
}

@cfg(os("macos"))
@test
func testUnixErrnoMapperWouldBlockMacos() {
    match std.sys.io.mapErrno(35) {
        case .wouldBlock => {}
        case _ => std.panic.panic("macOS EWOULDBLOCK should map to wouldBlock")
    }
}

@test
func testUnixErrnoMapperFallsBackToUnexpected() {
    match std.sys.io.mapErrno(999) {
        case .unexpected(code) => std.assert(code == 999, "unexpected should preserve the raw errno")
        case _ => std.panic.panic("unknown errno should map to unexpected")
    }
}
