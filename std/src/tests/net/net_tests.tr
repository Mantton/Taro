@cfg(family("unix"))
const FRAME_HEADER_LEN: usize = 4

@cfg(family("unix"))
func ipv6Loopback(_ port: uint16) -> std.net.SocketAddress {
    let ip: std.net.IpAddress = .ipv6([
        0_u8, 0_u8, 0_u8, 0_u8,
        0_u8, 0_u8, 0_u8, 0_u8,
        0_u8, 0_u8, 0_u8, 0_u8,
        0_u8, 0_u8, 0_u8, 1_u8,
    ])
    return std.net.SocketAddress {
        ip,
        port,
    }
}

@cfg(family("unix"))
func byteSpan(_ value: &uint8) -> std.mem.Span[uint8] {
    return std.mem.Span[uint8].from(unsafe { value as *const uint8 }, 1)
}

@cfg(family("unix"))
func byteMutSpan(_ value: &mut uint8) -> std.mem.MutableSpan[uint8] {
    return std.mem.MutableSpan[uint8].from(unsafe { value as *mut uint8 }, 1)
}

@cfg(family("unix"))
func headerSpan(_ header: &[uint8; FRAME_HEADER_LEN]) -> std.mem.Span[uint8] {
    let ptr = unsafe { (header as *const [uint8; FRAME_HEADER_LEN]) as *const uint8 }
    return std.mem.Span[uint8].from(ptr, FRAME_HEADER_LEN)
}

@cfg(family("unix"))
func headerMutSpan(_ header: &mut [uint8; FRAME_HEADER_LEN]) -> std.mem.MutableSpan[uint8] {
    let ptr = unsafe { (header as *mut [uint8; FRAME_HEADER_LEN]) as *mut uint8 }
    return std.mem.MutableSpan[uint8].from(ptr, FRAME_HEADER_LEN)
}

@cfg(family("unix"))
func stringBytes(_ s: string) -> std.mem.Span[uint8] {
    let len = std.string.stringLen(s)
    if len == 0 {
        return std.mem.Span[uint8].from(std.string.stringData(""), 0)
    }
    return std.mem.Span[uint8].from(std.string.stringData(s), len)
}

@cfg(family("unix"))
func mutableSpanFromPtr(_ ptr: *mut uint8, _ len: usize) -> std.mem.MutableSpan[uint8] {
    return std.mem.MutableSpan[uint8].from(ptr, len)
}

@cfg(family("unix"))
func encodeFrameLength(_ len: usize) -> [uint8; FRAME_HEADER_LEN] {
    let value = len as uint32
    return [
        ((value >> 24_u32) & 255_u32) as uint8,
        ((value >> 16_u32) & 255_u32) as uint8,
        ((value >> 8_u32) & 255_u32) as uint8,
        (value & 255_u32) as uint8,
    ]
}

@cfg(family("unix"))
func decodeFrameLength(_ header: &[uint8; FRAME_HEADER_LEN]) -> usize {
    let b0 = (*header.at(0 as usize) as uint32) << 24_u32
    let b1 = (*header.at(1 as usize) as uint32) << 16_u32
    let b2 = (*header.at(2 as usize) as uint32) << 8_u32
    let b3 = *header.at(3 as usize) as uint32
    return (b0 | b1 | b2 | b3) as usize
}

@cfg(family("unix"))
func transformedMessage(_ request: string) -> string {
    return "server<" + request + ">:ok"
}

@cfg(family("unix"))
func expectUnexpectedCode(_ err: std.io.Error, _ code: int32, _ message: string) {
    match err {
        case .unexpected(actual) => std.testing.assertEqual(actual, code, message)
        case _ => std.panic.panic(message)
    }
}

@cfg(family("unix"))
func acceptEchoByte(_ listener: &std.net.TcpListener, _ expected: uint8) async {
    let acceptRes = await listener.accept()
    let accepted = match acceptRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("accept should succeed")
    }

    let stream = accepted.0
    var received: uint8 = 0
    let readRes = await stream.read(byteMutSpan(&mut received))
    let readCount = match readRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("server read should succeed")
    }
    std.testing.assertEqual(readCount, 1 as usize, "server should read exactly one byte")
    std.testing.assertEqual(received, expected, "server should receive the expected byte")

    let writeRes = await stream.write(byteSpan(&received))
    let writeCount = match writeRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("server write should succeed")
    }
    std.testing.assertEqual(writeCount, 1 as usize, "server should write exactly one byte")

    match stream.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("accepted stream close should succeed")
    }
}

@cfg(family("unix"))
func acceptAndEchoClients(_ listener: &std.net.TcpListener, _ expectedClients: int32) async -> int32 {
    var handled: int32 = 0

    while handled < expectedClients {
        let acceptRes = await listener.accept()
        let pair = match acceptRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("async listener accept should succeed")
        }

        let stream = pair.0
        var received: uint8 = 0
        let readRes = await stream.read(byteMutSpan(&mut received))
        let readCount = match readRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("async server read should succeed")
        }
        std.testing.assertEqual(readCount, 1 as usize, "async server should read one byte per client")

        let writeRes = await stream.write(byteSpan(&received))
        let writeCount = match writeRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("async server write should succeed")
        }
        std.testing.assertEqual(writeCount, 1 as usize, "async server should write one byte per client")

        match stream.close() {
            case .ok(_) => {}
            case .err(_) => std.panic.panic("async accepted stream close should succeed")
        }

        handled += 1
    }

    return handled
}

@cfg(family("unix"))
func writeMessage(_ stream: &std.net.TcpStream, _ message: string) async {
    let header = encodeFrameLength(std.string.stringLen(message))
    let headerRes = await stream.writeAll(headerSpan(&header))
    match headerRes {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("writeAll header should succeed")
    }

    let writeRes = await stream.write(message)
    match writeRes {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("write string should succeed")
    }
}

@cfg(family("unix"))
func readMessage(_ stream: &std.net.TcpStream) async -> string {
    var header: [uint8; FRAME_HEADER_LEN] = [0; FRAME_HEADER_LEN]
    let headerRes = await stream.readExact(headerMutSpan(&mut header))
    match headerRes {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("readExact header should succeed")
    }

    let payloadLen = decodeFrameLength(&header)
    if payloadLen == 0 {
        return ""
    }

    let payload = std.mem.allocBytes(payloadLen)
    let payloadRes = await stream.readExact(mutableSpanFromPtr(payload, payloadLen))
    match payloadRes {
        case .ok(_) => return std.string.stringFromParts(payload, payloadLen)
        case .err(_) => std.panic.panic("readExact payload should succeed")
    }
}

@cfg(family("unix"))
func acceptAndTransformMessages(_ listener: &std.net.TcpListener, _ expectedClients: int32) async -> int32 {
    var handled: int32 = 0

    while handled < expectedClients {
        let acceptRes = await listener.accept()
        let pair = match acceptRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("string listener accept should succeed")
        }

        let stream = pair.0
        let request = await readMessage(&stream)
        let response = transformedMessage(request)
        await writeMessage(&stream, response)

        match stream.close() {
            case .ok(_) => {}
            case .err(_) => std.panic.panic("string server close should succeed")
        }

        handled += 1_i32
    }

    return handled
}

@cfg(family("unix"))
func clientRoundTrip(_ address: std.net.SocketAddress, _ value: uint8) async -> int32 {
    let connectRes = await std.net.TcpStream.connect(address)
    let stream = match connectRes {
        case .ok(inner) => inner
        case .err(_) => std.panic.panic("concurrent async connect should succeed")
    }

    var outbound = value
    let writeRes = await stream.write(byteSpan(&outbound))
    let writeCount = match writeRes {
        case .ok(inner) => inner
        case .err(_) => std.panic.panic("concurrent async write should succeed")
    }
    std.testing.assertEqual(writeCount, 1 as usize, "concurrent async client should write one byte")

    var echoed: uint8 = 0
    let readRes = await stream.read(byteMutSpan(&mut echoed))
    let readCount = match readRes {
        case .ok(inner) => inner
        case .err(_) => std.panic.panic("concurrent async read should succeed")
    }
    std.testing.assertEqual(readCount, 1 as usize, "concurrent async client should read one byte")

    match stream.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("concurrent async client close should succeed")
    }

    return echoed as int32
}

@cfg(family("unix"))
@test
func tcpLocalAddressReflectsEphemeralPortIpv4() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("ipv4 listen should succeed")
    }

    let localRes = listener.localAddress()
    let local = match localRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("ipv4 localAddress should succeed")
    }
    std.testing.assertTrue(local.port != 0_u16, "port 0 bind should allocate an ipv4 port")

    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("ipv4 listener close should succeed")
    }
}

