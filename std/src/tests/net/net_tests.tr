@cfg(family("unix"))
@test
func tcpClientServerEcho() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("listen should succeed")
    }
    let local = match listener.localAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("localAddress should succeed")
    }

    var outbound: uint8 = 44_u8
    let serverTask = std.task.spawn(|| async {
        return await clientRoundTrip(local, outbound)
    })

    let handled = await acceptAndEchoClients(&listener, 1_i32)
    std.testing.assertEqual(handled, 1_i32, "server side should handle one client")

    let echoed = await serverTask.value()
    std.testing.assertEqual(echoed, outbound as int32, "client should receive the echoed byte")

    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("listener close should succeed")
    }
}

@cfg(family("unix"))
@test
func tcpStreamReportsPeerAndLocalAddresses() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("listener should start")
    }

    let serverLocal = match listener.localAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("listener localAddress should succeed")
    }

    let connectRes = await std.net.TcpStream.connect(serverLocal)
    let client = match connectRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("connect should succeed")
    }

    let clientLocal = match client.localAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("client localAddress should succeed")
    }
    let clientPeer = match client.peerAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("client peerAddress should succeed")
    }
    std.testing.assertEqual(clientPeer.port, serverLocal.port, "client peerAddress should match listener port")
    std.testing.assertTrue(clientLocal.port != 0_u16, "client localAddress should have an ephemeral port")

    let acceptRes = await listener.accept()
    let accepted = match acceptRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("accept should succeed")
    }
    let serverStream = accepted.0
    let acceptedPeer = accepted.1
    let serverPeer = match serverStream.peerAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("accepted peerAddress should succeed")
    }

    std.testing.assertEqual(acceptedPeer.port, clientLocal.port, "accept should report the client port")
    std.testing.assertEqual(serverPeer.port, clientLocal.port, "accepted stream peerAddress should match the client port")

    match client.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("client close should succeed")
    }
    match serverStream.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("accepted stream close should succeed")
    }
    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("listener close should succeed")
    }
}

@cfg(family("unix"))
@test
func tcpStringRequestResponse() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("string listener should start")
    }

    let local = match listener.localAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("string localAddress should succeed")
    }

    let connectRes = await std.net.TcpStream.connect(local)
    let client = match connectRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("string connect should succeed")
    }

    let acceptRes = await listener.accept()
    let accepted = match acceptRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("string accept should succeed")
    }
    let server = accepted.0

    let request = "string request"
    await writeMessage(&client, request)
    let serverRequest = await readMessage(&server)
    std.testing.assertTrue(
        std.string.stringEq(serverRequest, request),
        "string server should receive the request payload",
    )

    await writeMessage(&server, transformedMessage(serverRequest))
    let response = await readMessage(&client)
    std.testing.assertTrue(
        std.string.stringEq(response, transformedMessage(request)),
        "string response should be transformed by the server",
    )

    match client.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("string client close should succeed")
    }
    match server.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("string server close should succeed")
    }

    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("string listener close should succeed")
    }
}

@cfg(family("unix"))
@test
func tcpAcceptsMultipleSequentialClients() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("listen should succeed")
    }
    let local = match listener.localAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("localAddress should succeed")
    }

    var idx: int32 = 0
    while idx < 3_i32 {
        let connectRes = await std.net.TcpStream.connect(local)
        let client = match connectRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("sequential connect should succeed")
        }

        var outbound: uint8 = (idx + 1_i32) as uint8
        let writeRes = await client.write(byteSpan(&outbound))
        let writeCount = match writeRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("sequential client write should succeed")
        }
        std.testing.assertEqual(writeCount, 1 as usize, "sequential client write should send one byte")

        await acceptEchoByte(&listener, outbound)

        var echoed: uint8 = 0
        let readRes = await client.read(byteMutSpan(&mut echoed))
        let readCount = match readRes {
            case .ok(value) => value
            case .err(_) => std.panic.panic("sequential client read should succeed")
        }
        std.testing.assertEqual(readCount, 1 as usize, "sequential client should read one byte")
        std.testing.assertEqual(echoed, outbound, "sequential echo should preserve the byte")

        match client.close() {
            case .ok(_) => {}
            case .err(_) => std.panic.panic("sequential client close should succeed")
        }

        idx += 1
    }

    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("listener close should succeed")
    }
}

@cfg(family("unix"))
@test
func syncUdpLoopbackRoundTrip() {
    let serverBind = std.net.SocketAddress.localhost(0_u16)
    let serverSocketRes = std.sys.net.socket(std.sys.net.domainForAddress(serverBind), .datagram)
    var server = match serverSocketRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp server socket should succeed")
    }

    match std.sys.net.bind(&server, serverBind) {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("udp server bind should succeed")
    }

    let serverAddr = match std.sys.net.localAddress(&server) {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp server localAddress should succeed")
    }
    std.testing.assertTrue(serverAddr.port != 0_u16, "udp server should get an ephemeral port")

    let clientSocketRes = std.sys.net.socket(std.sys.net.domainForAddress(serverAddr), .datagram)
    var client = match clientSocketRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp client socket should succeed")
    }

    var outbound: uint8 = 91_u8
    let sendRes = std.sys.net.sendTo(&client, unsafe { (&outbound as *const uint8) }, 1 as usize, serverAddr)
    let sendCount = match sendRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp sendTo should succeed")
    }
    std.testing.assertEqual(sendCount, 1 as usize, "udp sendTo should send one byte")

    var serverByte: uint8 = 0
    let recvRes = std.sys.net.recvFrom(&server, unsafe { (&mut serverByte as *mut uint8) }, 1 as usize)
    let received = match recvRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp recvFrom should succeed")
    }
    std.testing.assertEqual(received.0, 1 as usize, "udp recvFrom should receive one byte")
    std.testing.assertEqual(serverByte, outbound, "udp server should receive the sent byte")

    let replyRes = std.sys.net.sendTo(&server, unsafe { (&serverByte as *const uint8) }, 1 as usize, received.1)
    let replyCount = match replyRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp reply sendTo should succeed")
    }
    std.testing.assertEqual(replyCount, 1 as usize, "udp reply should send one byte")

    var clientByte: uint8 = 0
    let clientRecvRes = std.sys.net.recvFrom(&client, unsafe { (&mut clientByte as *mut uint8) }, 1 as usize)
    let clientReceived = match clientRecvRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("udp client recvFrom should succeed")
    }
    std.testing.assertEqual(clientReceived.0, 1 as usize, "udp client should receive one byte")
    std.testing.assertEqual(clientByte, outbound, "udp reply should echo the original byte")

    match std.sys.net.close(&mut client) {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("udp client close should succeed")
    }
    match std.sys.net.close(&mut server) {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("udp server close should succeed")
    }
}

@cfg(family("unix"))
@test
func closedListenerReturnsErrorOnAccept() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("listen should succeed")
    }

    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("first close should succeed")
    }
    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("second close should also succeed")
    }

    let acceptRes = await listener.accept()
    match acceptRes {
        case .ok(_) => std.panic.panic("accept on a closed listener should fail")
        case .err(err) => expectUnexpectedCode(err, 9, "closed listener should surface EBADF")
    }
}

@cfg(family("unix"))
@test
func tcpManyConcurrentClients() async {
    let listenRes = std.net.TcpListener.bind(std.net.SocketAddress.localhost(0_u16))
    var listener = match listenRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("listen should succeed")
    }
    let local = match listener.localAddress() {
        case .ok(value) => value
        case .err(_) => std.panic.panic("localAddress should succeed")
    }

    let clientCount = 4_i32
    var tasks = std.collections.List[std.task.Task[int32]]()
    var idx: int32 = 0
    while idx < clientCount {
        let value = (idx + 1_i32) as uint8
        let task = std.task.spawn(|| async {
            return await clientRoundTrip(local, value)
        })

        tasks.append(task)
        idx += 1
    }

    let handled = await acceptAndEchoClients(&listener, clientCount)
    std.testing.assertEqual(handled, clientCount, "server should handle every concurrent client")

    var seen: int32 = 0
    var taskIdx: usize = 0
    while taskIdx < tasks.len() {
        let echoed = await tasks.at(taskIdx).value()
        seen += echoed
        taskIdx += 1
    }

    std.testing.assertEqual(seen, 10_i32, "concurrent clients should all receive their echoed bytes")

    match listener.close() {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("listener close should succeed")
    }
}

@cfg(family("unix"))
@test
func asyncUdpLoopbackRoundTrip() async {
    let bindAddr = std.net.SocketAddress.localhost(0_u16)
    let serverSocketRes = std.sys.net.task.socket(std.sys.net.domainForAddress(bindAddr), .datagram)
    var server = match serverSocketRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp server socket should succeed")
    }

    match std.sys.net.task.bind(&server, bindAddr) {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("async udp server bind should succeed")
    }

    let serverAddr = match std.sys.net.task.localAddress(&server) {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp server localAddress should succeed")
    }
    std.testing.assertTrue(serverAddr.port != 0_u16, "async udp server should get an ephemeral port")

    let clientSocketRes = std.sys.net.task.socket(std.sys.net.domainForAddress(serverAddr), .datagram)
    var client = match clientSocketRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp client socket should succeed")
    }

    var outbound: uint8 = 109_u8
    let sendRes = await std.sys.net.task.sendTo(&client, byteSpan(&outbound), serverAddr)
    let sendCount = match sendRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp sendTo should succeed")
    }
    std.testing.assertEqual(sendCount, 1 as usize, "async udp sendTo should send one byte")

    var serverByte: uint8 = 0
    let recvRes = await std.sys.net.task.recvFrom(&server, byteMutSpan(&mut serverByte))
    let received = match recvRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp recvFrom should succeed")
    }
    std.testing.assertEqual(received.0, 1 as usize, "async udp recvFrom should receive one byte")
    std.testing.assertEqual(serverByte, outbound, "async udp server should receive the sent byte")

    let replyRes = await std.sys.net.task.sendTo(&server, byteSpan(&serverByte), received.1)
    let replyCount = match replyRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp reply sendTo should succeed")
    }
    std.testing.assertEqual(replyCount, 1 as usize, "async udp reply should send one byte")

    var clientByte: uint8 = 0
    let clientRecvRes = await std.sys.net.task.recvFrom(&client, byteMutSpan(&mut clientByte))
    let clientReceived = match clientRecvRes {
        case .ok(value) => value
        case .err(_) => std.panic.panic("async udp client recvFrom should succeed")
    }
    std.testing.assertEqual(clientReceived.0, 1 as usize, "async udp client should receive one byte")
    std.testing.assertEqual(clientByte, outbound, "async udp reply should echo the original byte")

    match std.sys.net.task.close(&mut client) {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("async udp client close should succeed")
    }
    match std.sys.net.task.close(&mut server) {
        case .ok(_) => {}
        case .err(_) => std.panic.panic("async udp server close should succeed")
    }
}
