@test
func testEnumerateHelperProducesIndexValuePairs() {
    let elems = std.iter.enumerate((2 as usize)..(5 as usize))
    var indices = std.collections.List[usize].new()
    var values = std.collections.List[usize].new()

    for pair in elems {
        let (index, value) = pair
        indices.append(index)
        values.append(value)
    }

    std.testing.assertEqual(indices.len(), 3 as usize, "enumerate length")
    std.testing.assertEqual(*indices.at(0), 0 as usize, "first index")
    std.testing.assertEqual(*values.at(0), 2 as usize, "first value")
    std.testing.assertEqual(*indices.at(1), 1 as usize, "second index")
    std.testing.assertEqual(*values.at(1), 3 as usize, "second value")
    std.testing.assertEqual(*indices.at(2), 2 as usize, "third index")
    std.testing.assertEqual(*values.at(2), 4 as usize, "third value")
}

@test
func testIterableEnumerateDefaultMethod() {
    let elems = ((7 as usize)..(10 as usize)).enumerate()
    var indices = std.collections.List[usize].new()
    var values = std.collections.List[usize].new()

    for pair in elems {
        let (index, value) = pair
        indices.append(index)
        values.append(value)
    }

    std.testing.assertEqual(indices.len(), 3 as usize, "enumerate length")
    std.testing.assertEqual(*indices.at(0), 0 as usize, "first index")
    std.testing.assertEqual(*values.at(0), 7 as usize, "first value")
}

@test
func testEnumerateInForLoop() {
    var indexSum = 0 as usize
    var valueSum = 0 as usize

    for pair in std.iter.enumerate((1 as usize)..(4 as usize)) {
        let (index, value) = pair
        indexSum += index
        valueSum += value
    }

    std.testing.assertEqual(indexSum, 3 as usize, "for-loop enumerate index sum mismatch")
    std.testing.assertEqual(valueSum, 6 as usize, "for-loop enumerate value sum mismatch")
}
