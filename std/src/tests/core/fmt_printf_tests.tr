import std.collections.List

struct TaggedValue {
    text: string
}

impl std.fmt.Display for TaggedValue {
    func display(&self, _ into: &mut std.fmt.Formatter) {
        into.writeString(self.text)
    }
}

impl std.fmt.Formattable for TaggedValue {
    func format(&self, _ into: &mut std.fmt.Formatter, _ spec: rune, _ state: &std.fmt.FormatState) {
        if spec == 'v' {
            into.writeString(self.text)
            return
        }

        std.panic.panic("TaggedValue only supports %v")
    }
}

struct DisplayOnlyValue {
    text: string
}

impl std.fmt.Display for DisplayOnlyValue {
    func display(&self, _ into: &mut std.fmt.Formatter) {
        into.writeString(self.text)
    }
}

struct PreferFormatValue {
    displayText: string
    formatText: string
}

impl std.fmt.Display for PreferFormatValue {
    func display(&self, _ into: &mut std.fmt.Formatter) {
        into.writeString(self.displayText)
    }
}

impl std.fmt.Formattable for PreferFormatValue {
    func format(&self, _ into: &mut std.fmt.Formatter, _ spec: rune, _ state: &std.fmt.FormatState) {
        if spec == 'v' {
            into.writeString(self.formatText)
            return
        }
        std.panic.panic("PreferFormatValue only supports %v")
    }
}

@test
func testPrintfBasic() {
    std.printf("x=%d y=%s z=%v\n", 7, "ok", true)
    std.printf("100%%\n")

    let runeAsByte: uint8 = 'A' as uint8
    std.testing.assertEqual(runeAsByte, 65_u8, "rune -> uint8 cast should preserve ASCII codepoint")

    let byteAsRune: rune = 66_u8 as rune
    std.testing.assertEqual(byteAsRune, 'B', "int literal -> rune cast should preserve ASCII codepoint")

    let tagged = TaggedValue { text: "custom" }
    std.printf("%v\n", tagged)
    std.printf("%v\n", 'B')
    std.printf("%d\n", 1)
}

@test
func testSprintfBasic() {
    let text = std.sprintf("x=%d y=%s z=%v pct=100%%", 7, "ok", true)
    std.testing.assertEqual(text, "x=7 y=ok z=true pct=100%", "sprintf should return rendered string")
}

@test
func testSprintfStressWithManualCollect() {
    var idx: int32 = 0_i32
    var last = ""

    while idx < 4096_i32 {
        last = std.sprintf("iter=%d label=%s ok=%v", idx, "stress", true)
        if idx % 64_i32 == 0_i32 {
            std.runtime.collect()
        }
        idx += 1_i32
    }

    std.testing.assertEqual(last, "iter=4095 label=stress ok=true", "looped sprintf should remain stable across manual GC")
}

@test
func testPrintfLoopedSmoke() {
    var idx: int32 = 0_i32
    while idx < 64_i32 {
        std.printf("printf-smoke idx=%d ok=%v\n", idx, true)
        if idx % 16_i32 == 0_i32 {
            std.runtime.collect()
        }
        idx += 1_i32
    }

    std.testing.assertEqual(idx, 64_i32, "looped printf should complete without crashing")
}

@test
func testDisplayFallbackAndFormattablePreference() {
    let display_only = DisplayOnlyValue { text: "display-only" }
    let display_only_text = std.sprintf("%v", display_only)
    std.testing.assertEqual(
        display_only_text,
        "display-only",
        "display-only values should format via Display fallback",
    )

    let prefer_format = PreferFormatValue {
        displayText: "display",
        formatText: "format",
    }
    let prefer_format_text = std.sprintf("%v", prefer_format)
    std.testing.assertEqual(
        prefer_format_text,
        "format",
        "Formattable should be preferred over Display fallback",
    )
}

@test
func testListDisplayFormatting() {
    var values = List[int32]()
    values.append(1)
    values.append(2)
    values.append(3)

    let rendered = std.sprintf("%v", values)
    std.testing.assertEqual(rendered, "[1, 2, 3]", "list should render with brackets and comma separators")
}

@test
func testListDisplayFallbackForDisplayOnlyElements() {
    var values = List[DisplayOnlyValue]()
    values.append(DisplayOnlyValue { text: "a" })
    values.append(DisplayOnlyValue { text: "b" })

    let rendered = std.sprintf("%v", values)
    std.testing.assertEqual(rendered, "[a, b]", "list should use Display when elements are display-only")
}

@test
func testListFormattableElementsPreferFormat() {
    var values = List[PreferFormatValue]()
    values.append(PreferFormatValue { displayText: "display-a", formatText: "format-a" })
    values.append(PreferFormatValue { displayText: "display-b", formatText: "format-b" })

    let rendered = std.sprintf("%v", values)
    std.testing.assertEqual(rendered, "[format-a, format-b]", "list should format elements via Formattable")
}

@test
func testListDisplayEmpty() {
    let values = List[int32]()
    let rendered = std.sprintf("%v", values)
    std.testing.assertEqual(rendered, "[]", "empty list should render as []")
}

@test
@expectPanic
func testPrintfDynamicRuntimePanic() {
    let format = "%q"
    std.printf(format, 1)
}
