import std.collections.List
import std.cmp.{Ordering, PartialOrd, Ord}
import std.optional.Optional

func sumRef(_ list: &List[int32]) -> int32 {
    var sum: int32 = 0
    for x in list {
        sum = sum + *x
    }
    return sum
}

func doubleViaMutIter(_ list: &mut List[int32]) {
    for x in list {
        *x = *x * 2
    }
}

func sumByValue(_ list: List[int32]) -> int32 {
    var sum: int32 = 0
    for x in list {
        sum = sum + x
    }
    return sum
}

func firstMutable(_ values: &mut List[int32?]) -> Optional[&mut int32] {
    let slot = values.at(0 as usize)
    return match slot {
        case .some(v) => .some(v)
        case .none => .none
    }
}

struct SizedString {
    value: string
}

impl std.ops.PartialEq for SizedString {
    public func eq(&self, _ other: &SizedString) -> bool {
        std.string.stringLen(self.value) == std.string.stringLen(other.value)
    }
}

impl PartialOrd for SizedString {
    func partialCmp(&self, _ other: &SizedString) -> Optional[Ordering] {
        .some(self.cmp(other))
    }
}

impl Ord for SizedString {
    func cmp(&self, _ other: &SizedString) -> Ordering {
        let lhsLen = std.string.stringLen(self.value)
        let rhsLen = std.string.stringLen(other.value)
        return if lhsLen == rhsLen {
            .equal
        } else if lhsLen < rhsLen {
            .less
        } else {
            .greater
        }
    }
}

@test
func testListBasicCreationAndAppend() {
    var list: List[string] = List()
    list.append("Foo")
    list.append("Bar")
    list.append("Baz")
    std.testing.assertEqual(list.len(), 3 as usize, "list append should update length")

    var withCapacity: List[string] = List(withCapacity: 10)
    withCapacity.append("x")
    std.testing.assertEqual(withCapacity.len(), 1 as usize, "capacity constructor should create usable list")
}

@test
func testListIteratorModes() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)
    list.append(3)

    std.testing.assertEqual(sumRef(&list), 6, "ref iterator sum mismatch")
    doubleViaMutIter(&mut list)
    std.testing.assertEqual(sumByValue(list), 12, "value iterator sum mismatch after mutation")
}

@test
func testListMutableIteratorNext() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)
    list.append(3)

    for elem in &mut list {
        *elem *= 2
    }

    std.testing.assertEqual(*list.at(0), 2, "mutable iterator should update first element")
    std.testing.assertEqual(*list.at(1), 4, "mutable iterator should update second element")
    std.testing.assertEqual(*list.at(2), 6, "mutable iterator should update third element")
}

@test
func testListStaticConstructorInference() {
    var fromCtor = List[rune]()
    fromCtor.append('a')
    fromCtor.append('b')
    std.testing.assertEqual(fromCtor.len(), 2 as usize, "ctor length mismatch")
    std.testing.assertEqual(*fromCtor.at(0), 'a', "ctor element 0 mismatch")
    std.testing.assertEqual(*fromCtor.at(1), 'b', "ctor element 1 mismatch")

    var fromStatic = List[rune].new()
    fromStatic.append('c')
    std.testing.assertEqual(fromStatic.len(), 1 as usize, "static new length mismatch")
    std.testing.assertEqual(*fromStatic.at(0), 'c', "static new element mismatch")

    var withCap: List[rune] = List[rune].new(withCapacity: 4)
    withCap.append('d')
    withCap.append('e')
    std.testing.assertEqual(withCap.len(), 2 as usize, "capacity new length mismatch")
    std.testing.assertEqual(*withCap.at(0), 'd', "capacity new element 0 mismatch")
    std.testing.assertEqual(*withCap.at(1), 'e', "capacity new element 1 mismatch")
}

@test
func testListAtMutOverloadInference() {
    var values: List[int32?] = List()
    let entry: int32? = .some(1)
    values.append(entry)

    let maybeRef = firstMutable(&mut values)
    std.testing.assertTrue(maybeRef.isSome(), "firstMutable should produce mutable reference for populated list")
    *maybeRef.unwrap() = 7

    let readBack = values.at(0 as usize)
    std.testing.assertTrue(readBack.isSome(), "list entry should remain present after mutable update")
    std.testing.assertEqual(
        readBack.unwrap(),
        7,
        "mutable overload inference should allow updating nested optional value",
    )
}

@test
func testListReserve() {
    var list: List[int32] = List()
    list.reserve(100 as usize)
    std.testing.assertTrue(list.capacity() >= (100 as usize), "reserve should ensure capacity >= requested")
    std.testing.assertEqual(list.len(), 0 as usize, "reserve should not change length")

    // Reserve less than current capacity should be a no-op
    let capBefore = list.capacity()
    list.reserve(50 as usize)
    std.testing.assertEqual(list.capacity(), capBefore, "reserve smaller should be no-op")
}

@test
func testListInsertAtBeginning() {
    var list: List[int32] = List()
    list.append(2)
    list.append(3)

    let ok = list.insert(at: 0 as usize, 1)
    std.testing.assertTrue(ok, "insert at 0 should succeed")
    std.testing.assertEqual(list.len(), 3 as usize, "insert should increase length")
    std.testing.assertEqual(*list.at(0), 1, "insert at 0: element 0")
    std.testing.assertEqual(*list.at(1), 2, "insert at 0: element 1")
    std.testing.assertEqual(*list.at(2), 3, "insert at 0: element 2")
}

@test
func testListInsertAtMiddle() {
    var list: List[int32] = List()
    list.append(1)
    list.append(3)

    let ok = list.insert(at: 1 as usize, 2)
    std.testing.assertTrue(ok, "insert at middle should succeed")
    std.testing.assertEqual(*list.at(0), 1, "insert middle: element 0")
    std.testing.assertEqual(*list.at(1), 2, "insert middle: element 1")
    std.testing.assertEqual(*list.at(2), 3, "insert middle: element 2")
}

@test
func testListInsertAtEnd() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)

    let ok = list.insert(at: 2 as usize, 3)
    std.testing.assertTrue(ok, "insert at end should succeed")
    std.testing.assertEqual(*list.at(2), 3, "insert at end: last element")
}

@test
func testListInsertOutOfBounds() {
    var list: List[int32] = List()
    list.append(1)

    let ok = list.insert(at: 5 as usize, 99)
    std.testing.assertFalse(ok, "insert beyond len should return false")
    std.testing.assertEqual(list.len(), 1 as usize, "insert failure should not change length")
}

@test
func testListRemoveAtFirst() {
    var list: List[int32] = List()
    list.append(10)
    list.append(20)
    list.append(30)

    let removed = list.removeAt(0 as usize)
    std.testing.assertTrue(removed.isSome(), "removeAt 0 should return some")
    std.testing.assertEqual(removed.unwrap(), 10, "removeAt 0 should return first element")
    std.testing.assertEqual(list.len(), 2 as usize, "removeAt should decrease length")
    std.testing.assertEqual(*list.at(0), 20, "after removeAt 0: element 0 shifted")
    std.testing.assertEqual(*list.at(1), 30, "after removeAt 0: element 1 shifted")
}

@test
func testListRemoveAtLast() {
    var list: List[int32] = List()
    list.append(10)
    list.append(20)

    let removed = list.removeAt(1 as usize)
    std.testing.assertTrue(removed.isSome(), "removeAt last should return some")
    std.testing.assertEqual(removed.unwrap(), 20, "removeAt last should return last element")
    std.testing.assertEqual(list.len(), 1 as usize, "removeAt last should decrease length")
}

@test
func testListRemoveAtOutOfBounds() {
    var list: List[int32] = List()
    list.append(1)

    let removed = list.removeAt(5 as usize)
    std.testing.assertTrue(removed.isNone(), "removeAt OOB should return none")
    std.testing.assertEqual(list.len(), 1 as usize, "removeAt OOB should not change length")
}

@test
func testListSort() {
    var list: List[int32] = List()
    list.append(5)
    list.append(2)
    list.append(8)
    list.append(1)
    list.append(4)

    list.sort()

    std.testing.assertEqual(*list.at(0), 1, "sort: element 0")
    std.testing.assertEqual(*list.at(1), 2, "sort: element 1")
    std.testing.assertEqual(*list.at(2), 4, "sort: element 2")
    std.testing.assertEqual(*list.at(3), 5, "sort: element 3")
    std.testing.assertEqual(*list.at(4), 8, "sort: element 4")
}

@test
func testListSortAlreadySorted() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)
    list.append(3)

    list.sort()

    std.testing.assertEqual(*list.at(0), 1, "sort already sorted: element 0")
    std.testing.assertEqual(*list.at(1), 2, "sort already sorted: element 1")
    std.testing.assertEqual(*list.at(2), 3, "sort already sorted: element 2")
}

@test
func testListSortEmpty() {
    var list: List[int32] = List()
    list.sort()
    std.testing.assertEqual(list.len(), 0 as usize, "sort empty list should remain empty")
}

@test
func testListStringPopAndRemoveAt() {
    var list: List[string] = List()
    list.append("alpha")
    list.append("beta")
    list.append("gamma")

    let removed = list.removeAt(1 as usize)
    std.testing.assertTrue(removed.isSome(), "removeAt should return removed string")
    std.testing.assertEqual(removed.unwrap(), "beta", "removeAt should return middle string")

    let popped = list.pop()
    std.testing.assertTrue(popped.isSome(), "pop should return removed string")
    std.testing.assertEqual(popped.unwrap(), "gamma", "pop should return last string")
    std.testing.assertEqual(*list.at(0), "alpha", "remaining string should stay in place")
}

@test
func testListStringIteratorAndSort() {
    var list: List[SizedString] = List()
    list.append(SizedString { value: "pear" })
    list.append(SizedString { value: "a" })
    list.append(SizedString { value: "orange" })

    list.sort()
    std.testing.assertEqual((*list.at(0)).value, "a", "sort should order shortest string first")
    std.testing.assertEqual((*list.at(1)).value, "pear", "sort should order middle string second")
    std.testing.assertEqual((*list.at(2)).value, "orange", "sort should order longest string last")

    var iter = list.iter()
    let first = iter.next()
    std.testing.assertTrue(first.isSome(), "string iterator should yield first item")
    match first {
        case .some(value) => {
            std.testing.assertEqual(value.value, "a", "string iterator should read sorted value")
        }
        case .none => {
            std.testing.assertTrue(false, "string iterator unexpectedly returned none")
        }
    }
}

@test
func testListFrom() {
    var iter = 1_i32..4_i32
    var list = List[int32].from(&mut iter.iter())

    std.testing.assertEqual(list.len(), 3 as usize, "from should collect 3 elements")
    std.testing.assertEqual(*list.at(0), 1, "from: element 0")
    std.testing.assertEqual(*list.at(1), 2, "from: element 1")
    std.testing.assertEqual(*list.at(2), 3, "from: element 2")
}

// --- COW (Copy-On-Write) Tests ---

@test
func testListCowAppendCopy() {
    var original: List[int32] = List()
    original.append(1)
    original.append(2)
    original.append(3)

    var copy = original
    copy.append(4)

    std.testing.assertEqual(original.len(), 3 as usize, "cow append: original length unchanged")
    std.testing.assertEqual(copy.len(), 4 as usize, "cow append: copy length updated")
    std.testing.assertEqual(*copy.at(3), 4, "cow append: copy[3] correct")
    std.testing.assertEqual(*original.at(0), 1, "cow append: original[0] intact")
}

@test
func testListCowMutateOriginal() {
    var original: List[int32] = List()
    original.append(10)
    original.append(20)
    original.append(30)

    var copy = original
    original.append(40)
    original.set(0 as usize, 99)

    std.testing.assertEqual(copy.len(), 3 as usize, "cow mutate orig: copy length unchanged")
    std.testing.assertEqual(*copy.at(0), 10, "cow mutate orig: copy[0] unchanged")
    std.testing.assertEqual(original.len(), 4 as usize, "cow mutate orig: original length updated")
    std.testing.assertEqual(*original.at(0), 99, "cow mutate orig: original[0] updated")
}

@test
func testListCowEmptyList() {
    var a: List[int32] = List()
    var b = a

    a.append(1)
    b.append(2)

    std.testing.assertEqual(a.len(), 1 as usize, "cow empty: a.len == 1")
    std.testing.assertEqual(b.len(), 1 as usize, "cow empty: b.len == 1")
    std.testing.assertEqual(*a.at(0), 1, "cow empty: a[0] == 1")
    std.testing.assertEqual(*b.at(0), 2, "cow empty: b[0] == 2")
}

@test
func testListCowMultipleCopies() {
    var a: List[int32] = List()
    a.append(1)
    a.append(2)
    a.append(3)

    var b = a
    var c = a
    var d = b

    b.append(4)
    c.set(0 as usize, 99)
    let _ = d.pop()

    std.testing.assertEqual(a.len(), 3 as usize, "cow multi: a unchanged")
    std.testing.assertEqual(*a.at(0), 1, "cow multi: a[0] intact")
    std.testing.assertEqual(b.len(), 4 as usize, "cow multi: b has 4")
    std.testing.assertEqual(*b.at(3), 4, "cow multi: b[3] == 4")
    std.testing.assertEqual(c.len(), 3 as usize, "cow multi: c same length")
    std.testing.assertEqual(*c.at(0), 99, "cow multi: c[0] == 99")
    std.testing.assertEqual(d.len(), 2 as usize, "cow multi: d has 2")
}

@test
func testListCowPopOnCopy() {
    var original: List[int32] = List()
    original.append(10)
    original.append(20)
    original.append(30)

    var copy = original
    let popped = copy.pop()

    std.testing.assertTrue(popped.isSome(), "cow pop: returns some")
    std.testing.assertEqual(popped.unwrap(), 30, "cow pop: returns last")
    std.testing.assertEqual(copy.len(), 2 as usize, "cow pop: copy len decreased")
    std.testing.assertEqual(original.len(), 3 as usize, "cow pop: original unchanged")
}

@test
func testListCowRemoveAtOnCopy() {
    var original: List[int32] = List()
    original.append(10)
    original.append(20)
    original.append(30)

    var copy = original
    let removed = copy.removeAt(1 as usize)

    std.testing.assertTrue(removed.isSome(), "cow removeAt: returns some")
    std.testing.assertEqual(removed.unwrap(), 20, "cow removeAt: returns middle")
    std.testing.assertEqual(copy.len(), 2 as usize, "cow removeAt: copy len decreased")
    std.testing.assertEqual(*copy.at(0), 10, "cow removeAt: copy[0] correct")
    std.testing.assertEqual(*copy.at(1), 30, "cow removeAt: copy[1] shifted")
    std.testing.assertEqual(original.len(), 3 as usize, "cow removeAt: original unchanged")
}

@test
func testListCowInsertOnCopy() {
    var original: List[int32] = List()
    original.append(1)
    original.append(3)

    var copy = original
    let ok = copy.insert(at: 1 as usize, 2)

    std.testing.assertTrue(ok, "cow insert: should succeed")
    std.testing.assertEqual(copy.len(), 3 as usize, "cow insert: copy has 3")
    std.testing.assertEqual(*copy.at(1), 2, "cow insert: copy[1] == 2")
    std.testing.assertEqual(original.len(), 2 as usize, "cow insert: original unchanged")
}

@test
func testListCowClearOnCopy() {
    var original: List[int32] = List()
    original.append(1)
    original.append(2)
    original.append(3)

    var copy = original
    copy.clear()

    std.testing.assertEqual(copy.len(), 0 as usize, "cow clear: copy empty")
    std.testing.assertTrue(copy.isEmpty(), "cow clear: copy isEmpty")
    std.testing.assertEqual(original.len(), 3 as usize, "cow clear: original unchanged")
}

@test
func testListCowReserveOnCopy() {
    var original: List[int32] = List()
    original.append(1)
    original.append(2)

    var copy = original
    copy.reserve(100 as usize)

    std.testing.assertTrue(copy.capacity() >= (100 as usize), "cow reserve: copy capacity grown")
    std.testing.assertEqual(copy.len(), 2 as usize, "cow reserve: copy len unchanged")
    std.testing.assertEqual(*copy.at(0), 1, "cow reserve: copy[0] intact")
    std.testing.assertEqual(original.len(), 2 as usize, "cow reserve: original unchanged")
}

@test
func testListCowSortOnCopy() {
    var original: List[int32] = List()
    original.append(3)
    original.append(1)
    original.append(2)

    var copy = original
    copy.sort()

    std.testing.assertEqual(*copy.at(0), 1, "cow sort: copy[0] sorted")
    std.testing.assertEqual(*copy.at(1), 2, "cow sort: copy[1] sorted")
    std.testing.assertEqual(*copy.at(2), 3, "cow sort: copy[2] sorted")
    std.testing.assertEqual(*original.at(0), 3, "cow sort: original[0] unchanged")
    std.testing.assertEqual(*original.at(1), 1, "cow sort: original[1] unchanged")
}

@test
func testListCowMutIterOnCopy() {
    var original: List[int32] = List()
    original.append(1)
    original.append(2)
    original.append(3)

    var copy = original

    for elem in &mut copy {
        *elem *= 10
    }

    std.testing.assertEqual(*copy.at(0), 10, "cow mut iter: copy[0] updated")
    std.testing.assertEqual(*copy.at(1), 20, "cow mut iter: copy[1] updated")
    std.testing.assertEqual(*copy.at(2), 30, "cow mut iter: copy[2] updated")
    std.testing.assertEqual(*original.at(0), 1, "cow mut iter: original[0] unchanged")
    std.testing.assertEqual(*original.at(1), 2, "cow mut iter: original[1] unchanged")
}

@test
func testListCowSetOnCopy() {
    var original: List[int32] = List()
    original.append(10)
    original.append(20)
    original.append(30)

    var copy = original
    copy.set(1 as usize, 99)

    std.testing.assertEqual(*copy.at(1), 99, "cow set: copy[1] updated")
    std.testing.assertEqual(*original.at(1), 20, "cow set: original[1] unchanged")
}

@test
func testListCowAtMutOnCopy() {
    var original: List[int32] = List()
    original.append(5)
    original.append(10)
    original.append(15)

    var copy = original
    *copy.at(0 as usize) = 50

    std.testing.assertEqual(*copy.at(0), 50, "cow at_mut: copy[0] updated")
    std.testing.assertEqual(*original.at(0), 5, "cow at_mut: original[0] unchanged")
}

@test
func testListCowStringValues() {
    var original: List[string] = List()
    original.append("hello")
    original.append("world")

    var copy = original
    copy.append("!")
    copy.set(0 as usize, "goodbye")

    std.testing.assertEqual(original.len(), 2 as usize, "cow string: original len unchanged")
    std.testing.assertEqual(*original.at(0), "hello", "cow string: original[0] unchanged")
    std.testing.assertEqual(copy.len(), 3 as usize, "cow string: copy len updated")
    std.testing.assertEqual(*copy.at(0), "goodbye", "cow string: copy[0] updated")
    std.testing.assertEqual(*copy.at(2), "!", "cow string: copy[2] appended")
}
