import std.collections.List
import std.optional.Optional

func sumRef(_ list: &List[int32]) -> int32 {
    var sum: int32 = 0
    for x in list {
        sum = sum + *x
    }
    return sum
}

func doubleViaMutIter(_ list: &mut List[int32]) {
    for x in list {
        *x = *x * 2
    }
}

func sumByValue(_ list: List[int32]) -> int32 {
    var sum: int32 = 0
    for x in list {
        sum = sum + x
    }
    return sum
}

func firstMutable(_ values: &mut List[int32?]) -> Optional[&mut int32] {
    let slot = values.at(0 as usize)
    return match slot {
        case .some(v) => .some(v)
        case .none => .none
    }
}

@test
func testListBasicCreationAndAppend() {
    var list: List[string] = List()
    list.append("Foo")
    list.append("Bar")
    list.append("Baz")
    std.testing.assertEqual(list.len(), 3 as usize, "list append should update length")

    var withCapacity: List[string] = List(withCapacity: 10)
    withCapacity.append("x")
    std.testing.assertEqual(withCapacity.len(), 1 as usize, "capacity constructor should create usable list")
}

@test
func testListIteratorModes() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)
    list.append(3)

    std.testing.assertEqual(sumRef(&list), 6, "ref iterator sum mismatch")
    doubleViaMutIter(&mut list)
    std.testing.assertEqual(sumByValue(list), 12, "value iterator sum mismatch after mutation")
}

@test
func testListMutableIteratorNext() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)
    list.append(3)

    for elem in &mut list {
        *elem *= 2
    }

    std.testing.assertEqual(*list.at(0), 2, "mutable iterator should update first element")
    std.testing.assertEqual(*list.at(1), 4, "mutable iterator should update second element")
    std.testing.assertEqual(*list.at(2), 6, "mutable iterator should update third element")
}

@test
func testListStaticConstructorInference() {
    var fromCtor = List[rune]()
    fromCtor.append('a')
    fromCtor.append('b')
    std.testing.assertEqual(fromCtor.len(), 2 as usize, "ctor length mismatch")
    std.testing.assertEqual(*fromCtor.at(0), 'a', "ctor element 0 mismatch")
    std.testing.assertEqual(*fromCtor.at(1), 'b', "ctor element 1 mismatch")

    var fromStatic = List[rune].new()
    fromStatic.append('c')
    std.testing.assertEqual(fromStatic.len(), 1 as usize, "static new length mismatch")
    std.testing.assertEqual(*fromStatic.at(0), 'c', "static new element mismatch")

    var withCap: List[rune] = List[rune].new(withCapacity: 4)
    withCap.append('d')
    withCap.append('e')
    std.testing.assertEqual(withCap.len(), 2 as usize, "capacity new length mismatch")
    std.testing.assertEqual(*withCap.at(0), 'd', "capacity new element 0 mismatch")
    std.testing.assertEqual(*withCap.at(1), 'e', "capacity new element 1 mismatch")
}

@test
func testListAtMutOverloadInference() {
    var values: List[int32?] = List()
    let entry: int32? = .some(1)
    values.append(entry)

    let maybeRef = firstMutable(&mut values)
    std.testing.assertTrue(maybeRef.isSome(), "firstMutable should produce mutable reference for populated list")
    *maybeRef.unwrap() = 7

    let readBack = values.at(0 as usize)
    std.testing.assertTrue(readBack.isSome(), "list entry should remain present after mutable update")
    std.testing.assertEqual(
        readBack.unwrap(),
        7,
        "mutable overload inference should allow updating nested optional value",
    )
}

@test
func testListReserve() {
    var list: List[int32] = List()
    list.reserve(100 as usize)
    std.testing.assertTrue(list.capacity() >= (100 as usize), "reserve should ensure capacity >= requested")
    std.testing.assertEqual(list.len(), 0 as usize, "reserve should not change length")

    // Reserve less than current capacity should be a no-op
    let capBefore = list.capacity()
    list.reserve(50 as usize)
    std.testing.assertEqual(list.capacity(), capBefore, "reserve smaller should be no-op")
}

@test
func testListInsertAtBeginning() {
    var list: List[int32] = List()
    list.append(2)
    list.append(3)

    let ok = list.insert(at: 0 as usize, 1)
    std.testing.assertTrue(ok, "insert at 0 should succeed")
    std.testing.assertEqual(list.len(), 3 as usize, "insert should increase length")
    std.testing.assertEqual(*list.at(0), 1, "insert at 0: element 0")
    std.testing.assertEqual(*list.at(1), 2, "insert at 0: element 1")
    std.testing.assertEqual(*list.at(2), 3, "insert at 0: element 2")
}

@test
func testListInsertAtMiddle() {
    var list: List[int32] = List()
    list.append(1)
    list.append(3)

    let ok = list.insert(at: 1 as usize, 2)
    std.testing.assertTrue(ok, "insert at middle should succeed")
    std.testing.assertEqual(*list.at(0), 1, "insert middle: element 0")
    std.testing.assertEqual(*list.at(1), 2, "insert middle: element 1")
    std.testing.assertEqual(*list.at(2), 3, "insert middle: element 2")
}

@test
func testListInsertAtEnd() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)

    let ok = list.insert(at: 2 as usize, 3)
    std.testing.assertTrue(ok, "insert at end should succeed")
    std.testing.assertEqual(*list.at(2), 3, "insert at end: last element")
}

@test
func testListInsertOutOfBounds() {
    var list: List[int32] = List()
    list.append(1)

    let ok = list.insert(at: 5 as usize, 99)
    std.testing.assertFalse(ok, "insert beyond len should return false")
    std.testing.assertEqual(list.len(), 1 as usize, "insert failure should not change length")
}

@test
func testListRemoveAtFirst() {
    var list: List[int32] = List()
    list.append(10)
    list.append(20)
    list.append(30)

    let removed = list.removeAt(0 as usize)
    std.testing.assertTrue(removed.isSome(), "removeAt 0 should return some")
    std.testing.assertEqual(removed.unwrap(), 10, "removeAt 0 should return first element")
    std.testing.assertEqual(list.len(), 2 as usize, "removeAt should decrease length")
    std.testing.assertEqual(*list.at(0), 20, "after removeAt 0: element 0 shifted")
    std.testing.assertEqual(*list.at(1), 30, "after removeAt 0: element 1 shifted")
}

@test
func testListRemoveAtLast() {
    var list: List[int32] = List()
    list.append(10)
    list.append(20)

    let removed = list.removeAt(1 as usize)
    std.testing.assertTrue(removed.isSome(), "removeAt last should return some")
    std.testing.assertEqual(removed.unwrap(), 20, "removeAt last should return last element")
    std.testing.assertEqual(list.len(), 1 as usize, "removeAt last should decrease length")
}

@test
func testListRemoveAtOutOfBounds() {
    var list: List[int32] = List()
    list.append(1)

    let removed = list.removeAt(5 as usize)
    std.testing.assertTrue(removed.isNone(), "removeAt OOB should return none")
    std.testing.assertEqual(list.len(), 1 as usize, "removeAt OOB should not change length")
}

@test
func testListSort() {
    var list: List[int32] = List()
    list.append(5)
    list.append(2)
    list.append(8)
    list.append(1)
    list.append(4)

    list.sort()

    std.testing.assertEqual(*list.at(0), 1, "sort: element 0")
    std.testing.assertEqual(*list.at(1), 2, "sort: element 1")
    std.testing.assertEqual(*list.at(2), 4, "sort: element 2")
    std.testing.assertEqual(*list.at(3), 5, "sort: element 3")
    std.testing.assertEqual(*list.at(4), 8, "sort: element 4")
}

@test
func testListSortAlreadySorted() {
    var list: List[int32] = List()
    list.append(1)
    list.append(2)
    list.append(3)

    list.sort()

    std.testing.assertEqual(*list.at(0), 1, "sort already sorted: element 0")
    std.testing.assertEqual(*list.at(1), 2, "sort already sorted: element 1")
    std.testing.assertEqual(*list.at(2), 3, "sort already sorted: element 2")
}

@test
func testListSortEmpty() {
    var list: List[int32] = List()
    list.sort()
    std.testing.assertEqual(list.len(), 0 as usize, "sort empty list should remain empty")
}

@test
func testListFrom() {
    var iter = 1_i32..4_i32
    var list = List[int32].from(&mut iter.iter())

    std.testing.assertEqual(list.len(), 3 as usize, "from should collect 3 elements")
    std.testing.assertEqual(*list.at(0), 1, "from: element 0")
    std.testing.assertEqual(*list.at(1), 2, "from: element 1")
    std.testing.assertEqual(*list.at(2), 3, "from: element 2")
}
