import std.hash.{Hashable, Hasher}
import std.iter.{Iterator, Iterable}

@test
func testDictionaryLiteralAndConstructorInference() {
    let values: [int32: string] = [1: "one", 2: "two"]
    std.testing.assertEqual(values.len(), 2 as usize, "non-empty literal should infer destination type")
    std.testing.assertTrue(values.contains(1), "literal-inferred dictionary should contain inserted key")

    var fromLiteral: [int32: string] = [:]
    let _ = fromLiteral.insert(key: 10, value: "Hello, World")
    std.testing.assertTrue(fromLiteral.contains(10), "literal dictionary should support insert/contains")

    var fromTypedLiteral: [uint32: string] = [:]
    let _ = fromTypedLiteral.insert(key: 10, value: "Hello, World")
    std.testing.assertTrue(fromTypedLiteral.contains(10), "typed literal dictionary should support insert/contains")
}

struct CollisionKey {
    id: int32
}

impl std.ops.PartialEq for CollisionKey {
    public func eq(&self, _ other: &CollisionKey) -> bool {
        self.id == other.id
    }
}

impl Hashable for CollisionKey {
    public func hash[H: Hasher](&self, into hasher: &mut H) {
        // Constant marker forces all keys into the same hash stream.
        let marker: [uint8; 1] = [1]
        hasher.write(marker.asSpan())
    }
}

@test
func testCollisionInsertLookupOverwrite() {
    var dict: [CollisionKey: int32] = [:]

    let _ = dict.insert(key: CollisionKey { id: 1 }, value: 100)
    let _ = dict.insert(key: CollisionKey { id: 2 }, value: 200)

    let hit1 = dict.get(CollisionKey { id: 1 })
    let hit2 = dict.get(CollisionKey { id: 2 })
    std.testing.assertTrue(hit1.isSome(), "collision lookup should find key 1")
    std.testing.assertTrue(hit2.isSome(), "collision lookup should find key 2")
    std.testing.assertEqual(*hit1.unwrap(), 100, "collision key 1 value mismatch")
    std.testing.assertEqual(*hit2.unwrap(), 200, "collision key 2 value mismatch")

    let old2 = dict.insert(key: CollisionKey { id: 2 }, value: 201)
    std.testing.assertTrue(old2.isSome(), "collision overwrite should return previous value")
    std.testing.assertEqual(old2.unwrap(), 200, "collision overwrite previous value mismatch")
}

@test
func testRemoveTombstoneKeepsProbeChain() {
    var dict: [CollisionKey: int32] = [:]

    let _ = dict.insert(key: CollisionKey { id: 1 }, value: 100)
    let _ = dict.insert(key: CollisionKey { id: 2 }, value: 200)
    let _ = dict.insert(key: CollisionKey { id: 3 }, value: 300)

    let removed = dict.remove(CollisionKey { id: 2 })
    std.testing.assertTrue(removed.isSome(), "remove should return value for present collision key")
    std.testing.assertEqual(removed.unwrap(), 200, "removed value mismatch for collision key")

    let hit1 = dict.get(CollisionKey { id: 1 })
    let hit2 = dict.get(CollisionKey { id: 2 })
    let hit3 = dict.get(CollisionKey { id: 3 })
    std.testing.assertTrue(hit1.isSome(), "key 1 should still be reachable after tombstone creation")
    std.testing.assertTrue(hit2.isNone(), "removed key should not be reachable")
    std.testing.assertTrue(hit3.isSome(), "key 3 should remain reachable through tombstone")
}

@test
func testDeletedSlotCanBeReused() {
    var dict: [CollisionKey: int32] = [:]

    let _ = dict.insert(key: CollisionKey { id: 10 }, value: 1000)
    let _ = dict.insert(key: CollisionKey { id: 11 }, value: 1100)
    let _ = dict.remove(CollisionKey { id: 10 })

    let added = dict.insert(key: CollisionKey { id: 12 }, value: 1200)
    std.testing.assertTrue(added.isNone(), "insert into table with tombstone should behave as new insert")
    std.testing.assertEqual(dict.len(), 2 as usize, "len should account for tombstone reuse correctly")

    let hit11 = dict.get(CollisionKey { id: 11 })
    let hit12 = dict.get(CollisionKey { id: 12 })
    std.testing.assertTrue(hit11.isSome(), "existing key should survive tombstone reuse")
    std.testing.assertTrue(hit12.isSome(), "new key should be reachable after tombstone reuse")
    std.testing.assertEqual(*hit11.unwrap(), 1100, "key 11 value mismatch after tombstone reuse")
    std.testing.assertEqual(*hit12.unwrap(), 1200, "key 12 value mismatch after tombstone reuse")
}

@test
func testGrowthThresholdAndOverwrite() {
    var dict: [int32: int32] = [:]

    var i: int32 = 0
    while i < 13 {
        let previous = dict.insert(key: i, value: i + 100)
        std.testing.assertTrue(previous.isNone(), "new insert should return none before/at threshold")
        i += 1
    }

    std.testing.assertEqual(dict.len(), 13 as usize, "len should reflect threshold-crossing inserts")

    let overwrite = dict.insert(key: 5, value: 999)
    std.testing.assertTrue(overwrite.isSome(), "overwrite should return previous value after threshold growth")
    std.testing.assertEqual(overwrite.unwrap(), 105, "overwrite previous value mismatch after threshold growth")
    std.testing.assertEqual(dict.len(), 13 as usize, "overwrite should not change len")
}

@test
func testDictionaryIterators() {
    var dict: [int32: string] = [:]
    let _ = dict.insert(key: 1, value: "one")
    let _ = dict.insert(key: 2, value: "two")
    let _ = dict.insert(key: 3, value: "three")

    // keys()
    var keysIter = dict.keys()
    var keyCount: usize = 0
    loop {
        match keysIter.next() {
            case .some(k) => {
                std.testing.assertTrue(k == 1 || k == 2 || k == 3, "keys() yields invalid key")
                keyCount += 1
            }
            case .none => break
        }
    }
    std.testing.assertEqual(keyCount, 3 as usize, "keys() yields wrong number of elements")

    // values()
    var valuesIter = dict.values()
    var valCount: usize = 0
    loop {
        match valuesIter.next() {
            case .some(v) => {
                std.testing.assertTrue(v == "one" || v == "two" || v == "three", "values() yields invalid value")
                valCount += 1
            }
            case .none => break
        }
    }
    std.testing.assertEqual(valCount, 3 as usize, "values() yields wrong number of elements")

    // entries() via Iterable implementation (&dict)
    var entryCount: usize = 0
    for entry in &dict {
        let (k, v) = entry
        std.testing.assertTrue(k == 1 || k == 2 || k == 3, "entries() yields invalid key")
        std.testing.assertTrue(v == "one" || v == "two" || v == "three", "entries() yields invalid value")
        entryCount += 1
    }
    std.testing.assertEqual(entryCount, 3 as usize, "entries() yields wrong number of elements")

    // &mut dict iteration
    var mutEntryCount: usize = 0
    for entry in &mut dict {
        let (k, v) = entry
        std.testing.assertTrue(k == 1 || k == 2 || k == 3, "mut entries() yields invalid key")
        mutEntryCount += 1
    }
    std.testing.assertEqual(mutEntryCount, 3 as usize, "mut entries() yields wrong number of elements")
}

@test
func testDictionaryClear() {
    var dict: [int32: string] = [:]
    let _ = dict.insert(key: 1, value: "one")
    let _ = dict.insert(key: 2, value: "two")

    std.testing.assertEqual(dict.len(), 2 as usize, "dictionary should have 2 elements")
    std.testing.assertTrue(dict.contains(1), "should contain key 1")

    dict.clear()

    std.testing.assertEqual(dict.len(), 0 as usize, "dictionary should be empty after clear")
    std.testing.assertTrue(dict.isEmpty(), "isEmpty should be true")
    std.testing.assertTrue(dict.get(1).isNone(), "cleared dict shouldn't contain previous keys")
    std.testing.assertTrue(dict.get(2).isNone(), "cleared dict shouldn't contain previous keys")

    // Should be able to insert again
    let _ = dict.insert(key: 3, value: "three")
    std.testing.assertEqual(dict.len(), 1 as usize, "dictionary should have 1 element after insert")
    std.testing.assertTrue(dict.contains(3), "should contain new key")
}

// --- COW (Copy-On-Write) Tests ---

@test
func testDictionaryCowInsertCopy() {
    var original: [int32: string] = [1: "one", 2: "two"]
    var copy = original

    let _ = copy.insert(key: 3, value: "three")

    std.testing.assertEqual(original.len(), 2 as usize, "cow insert: original len unchanged")
    std.testing.assertTrue(original.contains(1), "cow insert: original has key 1")
    std.testing.assertTrue(original.contains(2), "cow insert: original has key 2")
    std.testing.assertFalse(original.contains(3), "cow insert: original missing key 3")
    std.testing.assertEqual(copy.len(), 3 as usize, "cow insert: copy len updated")
    std.testing.assertTrue(copy.contains(3), "cow insert: copy has key 3")
}

@test
func testDictionaryCowRemoveCopy() {
    var original: [int32: string] = [1: "one", 2: "two", 3: "three"]
    var copy = original

    let removed = copy.remove(2)
    std.testing.assertTrue(removed.isSome(), "cow remove: returns value")
    std.testing.assertEqual(removed.unwrap(), "two", "cow remove: correct value")

    std.testing.assertEqual(original.len(), 3 as usize, "cow remove: original len unchanged")
    std.testing.assertTrue(original.contains(2), "cow remove: original still has key 2")
    std.testing.assertEqual(copy.len(), 2 as usize, "cow remove: copy len decreased")
    std.testing.assertFalse(copy.contains(2), "cow remove: copy missing key 2")
}

@test
func testDictionaryCowOverwriteCopy() {
    var original: [int32: string] = [1: "one", 2: "two"]
    var copy = original

    let old = copy.insert(key: 1, value: "ONE")
    std.testing.assertTrue(old.isSome(), "cow overwrite: returns old value")
    std.testing.assertEqual(old.unwrap(), "one", "cow overwrite: old value correct")

    let origVal = original.get(1)
    std.testing.assertTrue(origVal.isSome(), "cow overwrite: original has key")
    std.testing.assertEqual(*origVal.unwrap(), "one", "cow overwrite: original value unchanged")

    let copyVal = copy.get(1)
    std.testing.assertTrue(copyVal.isSome(), "cow overwrite: copy has key")
    std.testing.assertEqual(*copyVal.unwrap(), "ONE", "cow overwrite: copy value updated")
}

@test
func testDictionaryCowClearCopy() {
    var original: [int32: string] = [1: "one", 2: "two"]
    var copy = original

    copy.clear()

    std.testing.assertEqual(copy.len(), 0 as usize, "cow clear: copy empty")
    std.testing.assertTrue(copy.isEmpty(), "cow clear: copy isEmpty")
    std.testing.assertEqual(original.len(), 2 as usize, "cow clear: original unchanged")
    std.testing.assertTrue(original.contains(1), "cow clear: original has key 1")
}

@test
func testDictionaryCowEmptyDict() {
    var a: [int32: string] = [:]
    var b = a

    let _ = a.insert(key: 1, value: "one")
    let _ = b.insert(key: 2, value: "two")

    std.testing.assertEqual(a.len(), 1 as usize, "cow empty: a has 1")
    std.testing.assertEqual(b.len(), 1 as usize, "cow empty: b has 1")
    std.testing.assertTrue(a.contains(1), "cow empty: a has key 1")
    std.testing.assertFalse(a.contains(2), "cow empty: a missing key 2")
    std.testing.assertTrue(b.contains(2), "cow empty: b has key 2")
    std.testing.assertFalse(b.contains(1), "cow empty: b missing key 1")
}

@test
func testDictionaryCowMultipleCopies() {
    var original: [int32: int32] = [1: 100, 2: 200]
    var copy1 = original
    var copy2 = original

    let _ = copy1.insert(key: 3, value: 300)
    let _ = copy2.remove(1)

    std.testing.assertEqual(original.len(), 2 as usize, "cow multi: original unchanged")
    std.testing.assertEqual(copy1.len(), 3 as usize, "cow multi: copy1 has 3")
    std.testing.assertTrue(copy1.contains(3), "cow multi: copy1 has key 3")
    std.testing.assertEqual(copy2.len(), 1 as usize, "cow multi: copy2 has 1")
    std.testing.assertFalse(copy2.contains(1), "cow multi: copy2 missing key 1")
}

@test
func testDictionaryCowGetReadonlyCopy() {
    var original: [int32: int32] = [1: 100, 2: 200]
    let copy = original

    match copy.get(1) {
        case .some(val) => std.testing.assertEqual(*val, 100, "cow get readonly: sees original value")
        case .none => std.testing.fail("cow get readonly: should find key")
    }

    std.testing.assertTrue(copy.get(99).isNone(), "cow get readonly: missing key returns none")
}
