import std.io.Error
import std.libc
import std.result.Result

public struct RawSocket {
    fd: int32
}

public enum IpAddress {
    case ipv4([uint8; 4])
    case ipv6([uint8; 16])
}

public struct SocketAddress {
    ip: IpAddress
    port: uint16
}

public enum SocketDomain {
    case ipv4
    case ipv6
}

public enum SocketType {
    case stream
    case datagram
}

const SOCKET_ADDRESS_STORAGE_LEN: usize = 28
const SOCKADDR_V4_LEN: std.libc.socklen_t = 16_u32
const SOCKADDR_V6_LEN: std.libc.socklen_t = 28_u32

impl SocketAddress {
    public func localhost(_ port: uint16) -> SocketAddress {
        SocketAddress { ip: IpAddress.ipv4([127_u8, 0_u8, 0_u8, 1_u8]), port }
    }

    public func unspecified(_ port: uint16) -> SocketAddress {
        SocketAddress { ip: IpAddress.ipv4([0_u8, 0_u8, 0_u8, 0_u8]), port }
    }

    public func ipv4(_ a: uint8, _ b: uint8, _ c: uint8, _ d: uint8, _ port: uint16) -> SocketAddress {
        SocketAddress { ip: IpAddress.ipv4([a, b, c, d]), port }
    }
}

public func domainForAddress(_ address: SocketAddress) -> SocketDomain {
    match address.ip {
        case .ipv4(_) => return .ipv4
        case .ipv6(_) => return .ipv6
    }
}

@cfg(family("unix"))
public func socket(_ domain: SocketDomain, _ type_: SocketType) -> Result[RawSocket, Error] {
    let fd = std.libc.socket(socketDomainValue(domain), socketTypeValue(type_), 0)
    if fd < 0 {
        return .err(std.sys.io.lastError())
    }

    let socket = RawSocket { fd }
    let cloexecRes = setCloseOnExecFd(fd)
    match cloexecRes {
        case .ok(_) => return .ok(socket)
        case .err(err) => {
            let _ = std.libc.close(fd)
            return .err(err)
        }
    }
}

@cfg(family("windows"))
public func socket(_ domain: SocketDomain, _ type_: SocketType) -> Result[RawSocket, Error] {
    std.panic.todo("std.sys.net.socket not implemented on windows yet")
}

@cfg(family("unix"))
public func bind(_ socket: &RawSocket, _ address: SocketAddress) -> Result[(), Error] {
    let (storage, len) = encodeSocketAddress(address)
    let ptr = unsafe { (&storage as *const [uint8; SOCKET_ADDRESS_STORAGE_LEN]) as *const uint8 }
    let res = std.libc.bind(socket.fd, ptr, len)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(())
}

@cfg(family("windows"))
public func bind(_ socket: &RawSocket, _ address: SocketAddress) -> Result[(), Error] {
    std.panic.todo("std.sys.net.bind not implemented on windows yet")
}

