@cfg(family("unix"))
public func sendTo(
    _ socket: &RawSocket,
    _ buf: *const uint8,
    _ len: usize,
    _ address: SocketAddress,
) -> Result[usize, Error] {
    let (storage, addrLen) = encodeSocketAddress(address)
    let addrPtr = unsafe { (&storage as *const [uint8; SOCKET_ADDRESS_STORAGE_LEN]) as *const uint8 }
    let res = std.libc.sendto(socket.fd, buf, len, 0, addrPtr, addrLen)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(res as usize)
}

