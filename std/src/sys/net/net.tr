public func listen(_ socket: &RawSocket, _ backlog: int32) -> Result[(), Error] {
    let res = std.libc.listen(socket.fd, backlog)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(())
}

@cfg(family("windows"))
public func listen(_ socket: &RawSocket, _ backlog: int32) -> Result[(), Error] {
    std.panic.todo("std.sys.net.listen not implemented on windows yet")
}

@cfg(family("unix"))
public func connect(_ socket: &RawSocket, _ address: SocketAddress) -> Result[(), Error] {
    let (storage, len) = encodeSocketAddress(address)
    let ptr = unsafe { (&storage as *const [uint8; SOCKET_ADDRESS_STORAGE_LEN]) as *const uint8 }
    let res = std.libc.connect(socket.fd, ptr, len)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(())
}

@cfg(family("windows"))
public func connect(_ socket: &RawSocket, _ address: SocketAddress) -> Result[(), Error] {
    std.panic.todo("std.sys.net.connect not implemented on windows yet")
}

@cfg(family("unix"))
public func accept(_ socket: &RawSocket) -> Result[(RawSocket, SocketAddress), Error] {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    var len: std.libc.socklen_t = SOCKET_ADDRESS_STORAGE_LEN as std.libc.socklen_t
    let ptr = unsafe { (&mut storage as *mut [uint8; SOCKET_ADDRESS_STORAGE_LEN]) as *mut uint8 }
    let lenPtr = unsafe { (&mut len as *mut std.libc.socklen_t) }
    let childFd = std.libc.accept(socket.fd, ptr, lenPtr)
    if childFd < 0 {
        return .err(std.sys.io.lastError())
    }

    let cloexecRes = setCloseOnExecFd(childFd)
    match cloexecRes {
        case .ok(_) => {}
        case .err(err) => {
            let _ = std.libc.close(childFd)
            return .err(err)
        }
    }

    let addressRes = decodeSocketAddress(storage, len)
    let address = match addressRes {
        case .ok(value) => value
        case .err(err) => {
            let _ = std.libc.close(childFd)
            return .err(err)
        }
    }

    return .ok((RawSocket { fd: childFd }, address))
}

@cfg(family("windows"))
public func accept(_ socket: &RawSocket) -> Result[(RawSocket, SocketAddress), Error] {
    std.panic.todo("std.sys.net.accept not implemented on windows yet")
}

@cfg(family("unix"))
public func close(_ socket: &mut RawSocket) -> Result[(), Error] {
    if socket.fd < 0 {
        return .ok(())
    }

    let res = std.libc.close(socket.fd)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    socket.fd = -1
    return .ok(())
}

@cfg(family("windows"))
public func close(_ socket: &mut RawSocket) -> Result[(), Error] {
    std.panic.todo("std.sys.net.close not implemented on windows yet")
}

