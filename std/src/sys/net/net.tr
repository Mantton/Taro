public func setCloseOnExec(_ socket: &RawSocket) -> Result[(), Error] {
    setCloseOnExecFd(socket.fd)
}

@cfg(family("windows"))
public func setCloseOnExec(_ socket: &RawSocket) -> Result[(), Error] {
    std.panic.todo("std.sys.net.setCloseOnExec not implemented on windows yet")
