@cfg(family("unix"))
public func localAddress(_ socket: &RawSocket) -> Result[SocketAddress, Error] {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    var len: std.libc.socklen_t = SOCKET_ADDRESS_STORAGE_LEN as std.libc.socklen_t
    let ptr = unsafe { (&mut storage as *mut [uint8; SOCKET_ADDRESS_STORAGE_LEN]) as *mut uint8 }
    let lenPtr = unsafe { (&mut len as *mut std.libc.socklen_t) }
    let res = std.libc.getsockname(socket.fd, ptr, lenPtr)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return decodeSocketAddress(storage, len)
}

