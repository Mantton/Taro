    _ address: SocketAddress,
) -> Result[usize, Error] {
    std.panic.todo("std.sys.net.sendTo not implemented on windows yet")
}

@cfg(family("unix"))
public func recvFrom(
    _ socket: &RawSocket,
    _ buf: *mut uint8,
    _ len: usize,
) -> Result[(usize, SocketAddress), Error] {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    var addrLen: std.libc.socklen_t = SOCKET_ADDRESS_STORAGE_LEN as std.libc.socklen_t
    let addrPtr = unsafe { (&mut storage as *mut [uint8; SOCKET_ADDRESS_STORAGE_LEN]) as *mut uint8 }
    let lenPtr = unsafe { (&mut addrLen as *mut std.libc.socklen_t) }
    let res = std.libc.recvfrom(socket.fd, buf, len, 0, addrPtr, lenPtr)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }

    let addressRes = decodeSocketAddress(storage, addrLen)
    match addressRes {
        case .ok(address) => return .ok((res as usize, address))
        case .err(err) => return .err(err)
    }
}

@cfg(family("windows"))
public func recvFrom(
    _ socket: &RawSocket,
    _ buf: *mut uint8,
    _ len: usize,
) -> Result[(usize, SocketAddress), Error] {
    std.panic.todo("std.sys.net.recvFrom not implemented on windows yet")
}

@cfg(family("unix"))
public func setReuseAddr(_ socket: &RawSocket, _ enabled: bool) -> Result[(), Error] {
    var value: int32 = if enabled { 1 } else { 0 }
    let valuePtr = unsafe { (&value as *const int32) as *const uint8 }
    let valueLen = std.mem.sizeOf[int32]() as std.libc.socklen_t
    let res = std.libc.setsockopt(
        socket.fd,
        std.libc.SOL_SOCKET,
        std.libc.SO_REUSEADDR,
        valuePtr,
        valueLen,
    )
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(())
}

@cfg(family("windows"))
public func setReuseAddr(_ socket: &RawSocket, _ enabled: bool) -> Result[(), Error] {
    std.panic.todo("std.sys.net.setReuseAddr not implemented on windows yet")
}

