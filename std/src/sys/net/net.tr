@cfg(family("unix"))
public func socketError(_ socket: &RawSocket) -> Result[int32, Error] {
    var value: int32 = 0
    var len: std.libc.socklen_t = std.mem.sizeOf[int32]() as std.libc.socklen_t
    let valuePtr = unsafe { (&mut value as *mut int32) as *mut uint8 }
    let lenPtr = unsafe { (&mut len as *mut std.libc.socklen_t) }
    let res = std.libc.getsockopt(
        socket.fd,
        std.libc.SOL_SOCKET,
        std.libc.SO_ERROR,
        valuePtr,
        lenPtr,
    )
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(value)
}

@cfg(family("windows"))
public func socketError(_ socket: &RawSocket) -> Result[int32, Error] {
    std.panic.todo("std.sys.net.socketError not implemented on windows yet")
}

public func fd(_ socket: &RawSocket) -> int32 {
    socket.fd
}

public func takeFd(_ socket: &mut RawSocket) -> int32 {
    let fd = socket.fd
    socket.fd = -1
    return fd
}

public func fromFd(_ fd: int32) -> RawSocket {
    RawSocket { fd }
}

@cfg(family("unix"))
func socketDomainValue(_ domain: SocketDomain) -> int32 {
    match domain {
        case .ipv4 => return std.libc.AF_INET
        case .ipv6 => return std.libc.AF_INET6
    }
}

@cfg(family("unix"))
func socketTypeValue(_ type_: SocketType) -> int32 {
    match type_ {
        case .stream => return std.libc.SOCK_STREAM
        case .datagram => return std.libc.SOCK_DGRAM
    }
}

@cfg(family("unix"))
func setCloseOnExecFd(_ fd: int32) -> Result[(), Error] {
    let current = std.libc.fcntl(fd, std.libc.F_GETFD, 0)
    if current < 0 {
        return .err(std.sys.io.lastError())
    }

    let updated = current | std.libc.FD_CLOEXEC
    let res = std.libc.fcntl(fd, std.libc.F_SETFD, updated)
    if res < 0 {
        return .err(std.sys.io.lastError())
    }
    return .ok(())
}

@cfg(family("unix"))
func portHighByte(_ port: uint16) -> uint8 {
    ((port >> 8_u16) & 255_u16) as uint8
}

@cfg(family("unix"))
func portLowByte(_ port: uint16) -> uint8 {
    (port & 255_u16) as uint8
}

@cfg(family("unix"))
func decodePort(_ high: uint8, _ low: uint8) -> uint16 {
    (((high as uint16) << 8_u16) | (low as uint16))
}

@cfg(family("unix"))
func encodeSocketAddress(_ address: SocketAddress) -> ([uint8; SOCKET_ADDRESS_STORAGE_LEN], std.libc.socklen_t) {
    match address.ip {
        case .ipv4(octets) => return encodeIpv4Address(octets, address.port)
        case .ipv6(octets) => return encodeIpv6Address(octets, address.port)
    }
}

@cfg(os("linux"))
func encodeIpv4Address(
    _ octets: [uint8; 4],
    _ port: uint16,
) -> ([uint8; SOCKET_ADDRESS_STORAGE_LEN], std.libc.socklen_t) {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    *storage.at(0) = std.libc.AF_INET as uint8
    *storage.at(1) = 0_u8
    *storage.at(2) = portHighByte(port)
    *storage.at(3) = portLowByte(port)
    *storage.at(4) = *octets.at(0)
    *storage.at(5) = *octets.at(1)
    *storage.at(6) = *octets.at(2)
    *storage.at(7) = *octets.at(3)
    return (storage, SOCKADDR_V4_LEN)
}

@cfg(os("macos"))
func encodeIpv4Address(
    _ octets: [uint8; 4],
    _ port: uint16,
) -> ([uint8; SOCKET_ADDRESS_STORAGE_LEN], std.libc.socklen_t) {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    *storage.at(0) = SOCKADDR_V4_LEN as uint8
    *storage.at(1) = std.libc.AF_INET as uint8
    *storage.at(2) = portHighByte(port)
    *storage.at(3) = portLowByte(port)
    *storage.at(4) = *octets.at(0)
    *storage.at(5) = *octets.at(1)
    *storage.at(6) = *octets.at(2)
    *storage.at(7) = *octets.at(3)
    return (storage, SOCKADDR_V4_LEN)
}

@cfg(os("linux"))
func encodeIpv6Address(
    _ octets: [uint8; 16],
    _ port: uint16,
) -> ([uint8; SOCKET_ADDRESS_STORAGE_LEN], std.libc.socklen_t) {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    *storage.at(0) = std.libc.AF_INET6 as uint8
    *storage.at(1) = 0_u8
    *storage.at(2) = portHighByte(port)
    *storage.at(3) = portLowByte(port)

    var idx: usize = 0
    while idx < 16 {
        *storage.at(8 + idx) = *octets.at(idx)
        idx += 1
    }

    return (storage, SOCKADDR_V6_LEN)
}

@cfg(os("macos"))
func encodeIpv6Address(
    _ octets: [uint8; 16],
    _ port: uint16,
) -> ([uint8; SOCKET_ADDRESS_STORAGE_LEN], std.libc.socklen_t) {
    var storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN] = [0; SOCKET_ADDRESS_STORAGE_LEN]
    *storage.at(0) = SOCKADDR_V6_LEN as uint8
    *storage.at(1) = std.libc.AF_INET6 as uint8
    *storage.at(2) = portHighByte(port)
    *storage.at(3) = portLowByte(port)

    var idx: usize = 0
    while idx < 16 {
        *storage.at(8 + idx) = *octets.at(idx)
        idx += 1
    }

    return (storage, SOCKADDR_V6_LEN)
}

@cfg(os("linux"))
func storageFamily(_ storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN]) -> int32 {
    return ((*storage.at(0) as int32) | ((*storage.at(1) as int32) << 8_i32))
}

@cfg(os("macos"))
func storageFamily(_ storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN]) -> int32 {
    return *storage.at(1) as int32
}

@cfg(family("unix"))
func decodeSocketAddress(
    _ storage: [uint8; SOCKET_ADDRESS_STORAGE_LEN],
    _ len: std.libc.socklen_t,
) -> Result[SocketAddress, Error] {
    let family = storageFamily(storage)
    if family == std.libc.AF_INET {
        if len < SOCKADDR_V4_LEN {
            return .err(Error.invalidInput)
        }

        let ip: [uint8; 4] = [
            *storage.at(4),
            *storage.at(5),
            *storage.at(6),
            *storage.at(7),
        ]
        let addressIp: IpAddress = .ipv4(ip)
        return .ok(SocketAddress {
            ip: addressIp,
            port: decodePort(*storage.at(2), *storage.at(3)),
        })
    }

    if family == std.libc.AF_INET6 {
        if len < SOCKADDR_V6_LEN {
            return .err(Error.invalidInput)
        }

        let ip: [uint8; 16] = [
            *storage.at(8),
            *storage.at(9),
            *storage.at(10),
            *storage.at(11),
            *storage.at(12),
            *storage.at(13),
            *storage.at(14),
            *storage.at(15),
            *storage.at(16),
            *storage.at(17),
            *storage.at(18),
            *storage.at(19),
            *storage.at(20),
            *storage.at(21),
            *storage.at(22),
            *storage.at(23),
        ]
        let addressIp: IpAddress = .ipv6(ip)
        return .ok(SocketAddress {
            ip: addressIp,
            port: decodePort(*storage.at(2), *storage.at(3)),
        })
    }

    return .err(Error.unsupported)
}
