/// Callable interfaces for closures and function-like types.
///
/// Under value semantics, callable types are modeled with shared-call traits only.

@lang("Fn")
public interface Fn[Args: Tuple, Output] {
    func call(&self, args: Args) -> Output
}

@lang("AsyncFn")
public interface AsyncFn[Args: Tuple, Output] {
    func callAsync(&self, args: Args) -> Output
}
